{% extends 'base.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #c2410c;
        --brown-mid:   #ea580c;
        --brown-acc:   #f97316;
        --brown-light: #fdba74;
        --cream:       #fff7ed;
        --cream2:      #ffedd5;
        --white:       #ffffff;
        --text:        #431407;
        --muted:       #b45309;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .cp-wrap { padding: 32px 36px; }

    /* ── ALERTS ── */
    .cp-alert {
        padding: 14px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
        border-left: 4px solid #f44336;
        background: #ffebee;
        color: #c62828;
    }

    /* ── HEADER ── */
    .cp-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .cp-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .cp-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .cp-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .cp-back {
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15);
        color: #fff;
        padding: 10px 22px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .cp-back:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* ── INFO BOX ── */
    .cp-info {
        background: var(--cream2);
        border-left: 4px solid var(--brown-light);
        border-radius: 12px;
        padding: 14px 18px;
        margin-bottom: 24px;
        font-size: 13px;
        color: var(--brown-mid);
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
    }
    .cp-info i { color: var(--brown-light); font-size: 16px; }

    /* ── FORM CARD ── */
    .cp-card {
        background: var(--white);
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }
    .cp-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .cp-card-title i { color: var(--brown-acc); }

    /* ── FIELDS ── */
    .cp-label {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 8px;
    }
    .cp-label i { color: var(--brown-light); font-size: 13px; }

    .cp-input-wrap { position: relative; margin-bottom: 6px; }
    .cp-input {
        width: 100%;
        padding: 13px 46px 13px 16px;
        border: 1.5px solid var(--cream2);
        border-radius: 10px;
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        background: var(--cream);
        outline: none;
        transition: border-color .2s, background .2s;
    }
    .cp-input:focus { border-color: var(--brown-acc); background: var(--white); }
    .cp-input::placeholder { color: var(--muted); }

    .cp-eye {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: var(--muted);
        font-size: 15px;
        background: none;
        border: none;
        padding: 0;
    }
    .cp-eye:hover { color: var(--brown-acc); }

    .cp-help {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 20px;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .cp-help i { font-size: 11px; }

    /* ── ACTIONS ── */
    .cp-actions {
        display: flex;
        gap: 12px;
        padding-top: 20px;
        border-top: 1.5px solid var(--cream2);
        margin-top: 8px;
    }
    .cp-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 40px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: background .2s, transform .2s;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }
    .cp-btn.primary { background: var(--brown-dark); color: #fff; }
    .cp-btn.primary:hover { background: var(--brown-acc); color: #fff; transform: translateY(-2px); }
    .cp-btn.cancel {
        background: transparent;
        color: var(--muted);
        border: 2px solid var(--cream2);
    }
    .cp-btn.cancel:hover { border-color: var(--brown-light); color: var(--text); transform: translateY(-2px); }
</style>
{% endblock %}

{% block body %}
<div class="cp-wrap">

    {# ── ALERTS ── #}
    {% for message in app.flashes('error') %}
        <div class="cp-alert"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
    {% endfor %}

    {# ── HEADER ── #}
    <div class="cp-header">
        <div>
            <h1><i class="fas fa-lock"></i> Change Password</h1>
            <p>Update your account password securely.</p>
        </div>
        <a href="{{ path('app_profile') }}" class="cp-back">
            <i class="fas fa-arrow-left"></i> Back to Profile
        </a>
    </div>

    {# ── FORM ── #}
    <div class="cp-card">
        <div class="cp-card-title">
            <i class="fas fa-key"></i> Password Details
        </div>

        <div class="cp-info">
            <i class="fas fa-shield-alt"></i>
            For security reasons, you need to enter your current password to change it.
        </div>

        <form method="post">

            {# Current Password #}
            <label class="cp-label" for="current_password">
                <i class="fas fa-lock"></i> Current Password
            </label>
            <div class="cp-input-wrap">
                <input type="password" name="current_password" id="current_password"
                       class="cp-input" placeholder="Enter current password" required>
                <button type="button" class="cp-eye" onclick="toggleField('current_password', 'eye1')">
                    <i class="fas fa-eye" id="eye1"></i>
                </button>
            </div>
            <div class="cp-help" style="margin-bottom:20px;">
                <i class="fas fa-info-circle"></i> Enter the password you currently use to log in.
            </div>

            {# New Password #}
            <label class="cp-label" for="new_password">
                <i class="fas fa-key"></i> New Password
            </label>
            <div class="cp-input-wrap">
                <input type="password" name="new_password" id="new_password"
                       class="cp-input" placeholder="Enter new password" required>
                <button type="button" class="cp-eye" onclick="toggleField('new_password', 'eye2')">
                    <i class="fas fa-eye" id="eye2"></i>
                </button>
            </div>
            <div class="cp-help">
                <i class="fas fa-info-circle"></i> Password must be at least 6 characters long.
            </div>

            {# Confirm Password #}
            <label class="cp-label" for="confirm_password">
                <i class="fas fa-check-double"></i> Confirm New Password
            </label>
            <div class="cp-input-wrap">
                <input type="password" name="confirm_password" id="confirm_password"
                       class="cp-input" placeholder="Re-enter new password" required>
                <button type="button" class="cp-eye" onclick="toggleField('confirm_password', 'eye3')">
                    <i class="fas fa-eye" id="eye3"></i>
                </button>
            </div>
            <div class="cp-help">
                <i class="fas fa-info-circle"></i> Must match your new password exactly.
            </div>

            <div class="cp-actions">
                <button type="submit" class="cp-btn primary">
                    <i class="fas fa-check"></i> Change Password
                </button>
                <a href="{{ path('app_profile') }}" class="cp-btn cancel">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>

</div>

<script>
function toggleField(fieldId, iconId) {
    const input = document.getElementById(fieldId);
    const icon = document.getElementById(iconId);
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
    }
}
</script>
{% endblock %}
