{% extends 'base.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #1d4ed8;
        --brown-mid:   #2563eb;
        --brown-acc:   #3b82f6;
        --brown-light: #93c5fd;
        --cream:       #eff6ff;
        --cream2:      #dbeafe;
        --white:       #ffffff;
        --text:        #1e293b;
        --muted:       #64748b;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .pe-wrap { padding: 32px 36px; }

    /* ── ALERTS ── */
    .pe-alert {
        padding: 14px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
        border-left: 4px solid #f44336;
        background: #ffebee;
        color: #c62828;
    }

    /* ── HEADER ── */
    .pe-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .pe-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .pe-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .pe-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .pe-back {
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15);
        color: #fff;
        padding: 10px 22px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .pe-back:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* ── FORM CARD ── */
    .pe-card {
        background: var(--white);
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }
    .pe-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .pe-card-title i { color: var(--brown-acc); }

    /* ── FORM FIELDS ── */
    .pe-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 7px;
    }
    .pe-label i { color: var(--brown-light); font-size: 13px; }
    .pe-input {
        width: 100%;
        padding: 13px 16px;
        border: 1.5px solid var(--cream2);
        border-radius: 10px;
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        background: var(--cream);
        outline: none;
        transition: border-color .2s, background .2s;
        margin-bottom: 22px;
    }
    .pe-input:focus { border-color: var(--brown-acc); background: var(--white); }
    .pe-input::placeholder { color: var(--muted); }

    /* ── ACTIONS ── */
    .pe-actions {
        display: flex;
        gap: 12px;
        padding-top: 20px;
        border-top: 1.5px solid var(--cream2);
        margin-top: 8px;
    }
    .pe-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 40px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: background .2s, transform .2s;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }
    .pe-btn.primary { background: var(--brown-dark); color: #fff; }
    .pe-btn.primary:hover { background: var(--brown-acc); color: #fff; transform: translateY(-2px); }
    .pe-btn.cancel {
        background: transparent;
        color: var(--muted);
        border: 2px solid var(--cream2);
    }
    .pe-btn.cancel:hover { border-color: var(--brown-light); color: var(--text); transform: translateY(-2px); }
</style>
{% endblock %}

{% block body %}
<div class="pe-wrap">

    {# ── ALERTS ── #}
    {% for message in app.flashes('error') %}
        <div class="pe-alert"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
    {% endfor %}

    {# ── HEADER ── #}
    <div class="pe-header">
        <div>
            <h1><i class="fas fa-user-edit"></i> Edit Profile</h1>
            <p>Update your account information below.</p>
        </div>
        <a href="{{ path('app_profile') }}" class="pe-back">
            <i class="fas fa-arrow-left"></i> Back to Profile
        </a>
    </div>

    {# ── FORM ── #}
    <div class="pe-card">
        <div class="pe-card-title">
            <i class="fas fa-id-card"></i> Account Details
        </div>

        <form method="post">
            <label class="pe-label" for="email">
                <i class="fas fa-envelope"></i> Email Address
            </label>
            <input type="email" name="email" id="email"
                   value="{{ user.email }}"
                   class="pe-input"
                   placeholder="you@example.com"
                   required>

            <div class="pe-actions">
                <button type="submit" class="pe-btn primary">
                    <i class="fas fa-check"></i> Save Changes
                </button>
                <a href="{{ path('app_profile') }}" class="pe-btn cancel">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>

</div>
{% endblock %}
