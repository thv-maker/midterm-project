{% extends 'base.html.twig' %}

{% block title %}Create New Stock{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark: #c2410c; --brown-acc: #f97316;
        --brown-light: #fdba74; --cream: #fff7ed;
        --cream2: #ffedd5; --white: #ffffff;
        --text: #431407; --muted: #b45309;
    }
    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }
    .sn-wrap { padding: 32px 36px; }
    .sn-header { background: var(--brown-dark); border-radius: 18px; padding: 28px 32px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; position: relative; overflow: hidden; }
    .sn-header::before { content: ''; position: absolute; top: -60px; right: -60px; width: 200px; height: 200px; border-radius: 50%; background: rgba(255,255,255,.04); }
    .sn-header h1 { font-family: 'Playfair Display', serif; font-size: 24px; color: #fff; margin: 0 0 4px; font-weight: 700; display: flex; align-items: center; gap: 10px; }
    .sn-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .sn-back { background: rgba(255,255,255,.1); border: 1.5px solid rgba(255,255,255,.15); color: #fff; padding: 10px 22px; border-radius: 30px; text-decoration: none; font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; position: relative; z-index: 1; }
    .sn-back:hover { background: rgba(255,255,255,.18); color: #fff; }
    .sn-card { background: var(--white); border-radius: 16px; padding: 32px; box-shadow: 0 2px 12px rgba(0,0,0,.05); }
    .sn-card-title { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1.5px solid var(--cream2); display: flex; align-items: center; gap: 10px; }
    .sn-card-title i { color: var(--brown-acc); }
    .sn-label { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
    .sn-label i { color: var(--brown-light); font-size: 13px; }
    .sn-card select, .sn-card input[type="text"], .sn-card input[type="number"], .sn-card input[type="datetime-local"] { width: 100%; padding: 13px 16px; border: 1.5px solid var(--cream2); border-radius: 10px; font-size: 14px; font-family: 'DM Sans', sans-serif; color: var(--text); background: var(--cream); outline: none; transition: border-color .2s; margin-bottom: 6px; }
    .sn-card select:focus, .sn-card input:focus { border-color: var(--brown-acc); background: var(--white); }
    .sn-help { font-size: 12px; color: var(--muted); margin-bottom: 20px; margin-top: 5px; display: flex; align-items: center; gap: 5px; }
    .sn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .sn-actions { display: flex; gap: 12px; padding-top: 20px; border-top: 1.5px solid var(--cream2); margin-top: 8px; }
    .sn-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; border-radius: 40px; font-size: 14px; font-weight: 700; text-decoration: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: background .2s, transform .2s; }
    .sn-btn.primary { background: var(--brown-dark); color: #fff; }
    .sn-btn.primary:hover { background: var(--brown-acc); color: #fff; transform: translateY(-2px); }
    .sn-btn.cancel { background: transparent; color: var(--muted); border: 2px solid var(--cream2); }
    .sn-btn.cancel:hover { border-color: var(--brown-light); color: var(--text); }
    @media (max-width: 768px) { .sn-row { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block body %}
<div class="sn-wrap">
    <div class="sn-header">
        <div>
            <h1><i class="fas fa-plus-circle"></i> Create New Stock</h1>
            <p>Add a new stock entry to the inventory system.</p>
        </div>
        <a href="{{ path('app_dashboard_stocks') }}" class="sn-back">
            <i class="fas fa-arrow-left"></i> Back to Stocks
        </a>
    </div>

    <div class="sn-card">
        <div class="sn-card-title">
            <i class="fas fa-boxes"></i> Stock Details
        </div>

        {{ form_start(form) }}

            <label class="sn-label"><i class="fas fa-coffee"></i> Product</label>
            {{ form_widget(form.product) }}
            {{ form_errors(form.product) }}
            <div class="sn-help"><i class="fas fa-info-circle"></i> Choose the product for this stock entry.</div>

            <div class="sn-row">
                <div>
                    <label class="sn-label"><i class="fas fa-cubes"></i> Quantity</label>
                    {{ form_widget(form.quantity) }}
                    {{ form_errors(form.quantity) }}
                    <div class="sn-help"><i class="fas fa-info-circle"></i> Current stock quantity available.</div>
                </div>
                <div>
                    <label class="sn-label"><i class="fas fa-exclamation-triangle"></i> Reorder Level</label>
                    {{ form_widget(form.reorderLevel) }}
                    {{ form_errors(form.reorderLevel) }}
                    <div class="sn-help"><i class="fas fa-info-circle"></i> Minimum quantity before reorder alert.</div>
                </div>
            </div>

            <label class="sn-label"><i class="fas fa-clock"></i> Last Updated</label>
            {{ form_widget(form.lastUpdated, {'attr': {'readonly': true}}) }}
            {{ form_errors(form.lastUpdated) }}
            <div class="sn-help"><i class="fas fa-info-circle"></i> Date and time of last stock update.</div>

            <div class="sn-actions">
                <button type="submit" class="sn-btn primary">
                    <i class="fas fa-check"></i> Create Stock
                </button>
                <a href="{{ path('app_dashboard_stocks') }}" class="sn-btn cancel">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}