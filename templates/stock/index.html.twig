{% extends 'base.html.twig' %}

{% block title %}Stock Management{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #3e1f0d;
        --brown-mid:   #6d4c41;
        --brown-acc:   #8B5E3C;
        --brown-light: #c49a6c;
        --cream:       #faf7f4;
        --cream2:      #f3ece4;
        --white:       #ffffff;
        --text:        #2b1a0f;
        --muted:       #9e8070;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .sm-wrap { padding: 32px 36px; }

    /* ── HEADER ── */
    .sm-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .sm-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .sm-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .sm-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .sm-add-btn {
        background: rgba(255,255,255,.12);
        border: 1.5px solid rgba(255,255,255,.2);
        color: #fff;
        padding: 11px 24px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .sm-add-btn:hover { background: rgba(255,255,255,.2); color: #fff; }

    /* ── STATS ── */
    .sm-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }
    .sm-stat {
        background: var(--white);
        border-radius: 16px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 18px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        border-left: 4px solid var(--brown-acc);
        transition: transform .3s, box-shadow .3s;
    }
    .sm-stat:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(0,0,0,.09); }
    .sm-stat.danger { border-left-color: #f44336; }
    .sm-stat.warning { border-left-color: #f57c00; }
    .sm-stat.success { border-left-color: #2e7d32; }
    .sm-stat-icon {
        width: 54px; height: 54px;
        border-radius: 14px;
        background: var(--cream2);
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
        color: var(--brown-mid);
        flex-shrink: 0;
    }
    .sm-stat.danger .sm-stat-icon  { background: #ffebee; color: #c62828; }
    .sm-stat.warning .sm-stat-icon { background: #fff3e0; color: #f57c00; }
    .sm-stat.success .sm-stat-icon { background: #e8f5e9; color: #2e7d32; }
    .sm-stat-label { font-size: 11px; color: var(--muted); font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
    .sm-stat-value { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: var(--text); line-height: 1; }

    /* ── TABLE CARD ── */
    .sm-card {
        background: var(--white);
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        overflow: hidden;
    }
    .sm-card-head {
        padding: 22px 28px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .sm-card-head h3 {
        font-family: 'Playfair Display', serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .sm-card-head h3 i { color: var(--brown-acc); }
    .sm-count { font-size: 13px; color: var(--muted); font-weight: 500; }

    /* ── TABLE ── */
    table.sm-table { width: 100%; border-collapse: collapse; }
    table.sm-table thead th {
        padding: 12px 18px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--cream);
        border-bottom: 2px solid var(--cream2);
    }
    table.sm-table tbody td {
        padding: 16px 18px;
        font-size: 13px;
        color: var(--text);
        border-bottom: 1.5px solid var(--cream2);
        vertical-align: middle;
    }
    table.sm-table tbody tr:last-child td { border-bottom: none; }
    table.sm-table tbody tr:hover td { background: var(--cream); }

    /* product cell */
    .sm-prod-cell { display: flex; align-items: center; gap: 12px; }
    .sm-prod-icon {
        width: 38px; height: 38px;
        border-radius: 10px;
        background: var(--cream2);
        display: flex; align-items: center; justify-content: center;
        color: var(--brown-mid);
        font-size: 15px;
        flex-shrink: 0;
    }
    .sm-prod-name { font-weight: 600; color: var(--text); font-size: 13px; }
    .sm-prod-id { font-size: 11px; color: var(--muted); }

    /* qty indicator */
    .sm-qty {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--text);
    }

    /* badges */
    .sm-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
    }
    .sm-badge.healthy { background: #e8f5e9; color: #2e7d32; }
    .sm-badge.low     { background: #fff3e0; color: #f57c00; }
    .sm-badge.out     { background: #ffebee; color: #c62828; }

    /* action buttons */
    .sm-actions { display: flex; gap: 6px; }
    .sm-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity .2s, transform .2s;
    }
    .sm-btn:hover { opacity: .85; transform: translateY(-1px); }
    .sm-btn.view { background: var(--cream2); color: var(--brown-dark); }
    .sm-btn.edit { background: #fff3e0; color: #e65100; }

    /* empty */
    .sm-empty { text-align: center; padding: 60px 20px; color: var(--muted); }
    .sm-empty i { font-size: 48px; opacity: .3; margin-bottom: 16px; display: block; }
    .sm-empty p { font-size: 15px; margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="sm-wrap">

    {# ── HEADER ── #}
    <div class="sm-header">
        <div>
            <h1><i class="fas fa-boxes"></i> Stock Management</h1>
            <p>Monitor and manage your product inventory levels.</p>
        </div>
        <a href="{{ path('app_dashboard_stock_new') }}" class="sm-add-btn">
            <i class="fas fa-plus"></i> Add New Stock
        </a>
    </div>

    {# ── STATS ── #}
    {% set outCount = 0 %}
    {% set lowCount = 0 %}
    {% set healthyCount = 0 %}
    {% for stock in stocks %}
        {% if stock.quantity == 0 %}
            {% set outCount = outCount + 1 %}
        {% elseif stock.quantity <= stock.reorderLevel %}
            {% set lowCount = lowCount + 1 %}
        {% else %}
            {% set healthyCount = healthyCount + 1 %}
        {% endif %}
    {% endfor %}

    <div class="sm-stats">
        <div class="sm-stat danger">
            <div class="sm-stat-icon"><i class="fas fa-times-circle"></i></div>
            <div>
                <div class="sm-stat-label">Out of Stock</div>
                <div class="sm-stat-value">{{ outCount }}</div>
            </div>
        </div>
        <div class="sm-stat warning">
            <div class="sm-stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
            <div>
                <div class="sm-stat-label">Low Stock</div>
                <div class="sm-stat-value">{{ lowCount }}</div>
            </div>
        </div>
        <div class="sm-stat success">
            <div class="sm-stat-icon"><i class="fas fa-check-circle"></i></div>
            <div>
                <div class="sm-stat-label">Healthy Stock</div>
                <div class="sm-stat-value">{{ healthyCount }}</div>
            </div>
        </div>
    </div>

    {# ── TABLE ── #}
    <div class="sm-card">
        <div class="sm-card-head">
            <h3><i class="fas fa-list"></i> All Stock Items</h3>
            <span class="sm-count">{{ stocks|length }} item{{ stocks|length != 1 ? 's' : '' }} found</span>
        </div>

        {% if stocks is empty %}
            <div class="sm-empty">
                <i class="fas fa-boxes"></i>
                <p>No stock items found in the system.</p>
            </div>
        {% else %}
            <div style="overflow-x:auto;">
                <table class="sm-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Reorder Level</th>
                            <th>Status</th>
                            <th>Last Updated</th>
                            <th>Added By</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stock in stocks %}
                        <tr>
                            <td>
                                <div class="sm-prod-cell">
                                    <div class="sm-prod-icon">
                                        <i class="fas fa-coffee"></i>
                                    </div>
                                    <div>
                                        <div class="sm-prod-name">{{ stock.product.name }}</div>
                                        <div class="sm-prod-id">#{{ stock.id }}</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="sm-qty">{{ stock.quantity }}</span></td>
                            <td>
                                <span style="color:var(--muted); font-size:13px;">
                                    <i class="fas fa-arrow-down" style="font-size:10px; margin-right:4px;"></i>
                                    {{ stock.reorderLevel }}
                                </span>
                            </td>
                            <td>
                                {% if stock.quantity == 0 %}
                                    <span class="sm-badge out"><i class="fas fa-times-circle"></i> Out of Stock</span>
                                {% elseif stock.quantity <= stock.reorderLevel %}
                                    <span class="sm-badge low"><i class="fas fa-exclamation-triangle"></i> Low Stock</span>
                                {% else %}
                                    <span class="sm-badge healthy"><i class="fas fa-check-circle"></i> Healthy</span>
                                {% endif %}
                            </td>
                            <td>
                                <span style="color:var(--muted); font-size:13px;">
                                    <i class="far fa-calendar" style="margin-right:4px;"></i>
                                    {{ stock.lastUpdated|date('M d, Y') }}
                                </span>
                            </td>
                            <td>
    <span style="color:var(--muted); font-size:13px;">
        <i class="fas fa-user" style="margin-right:4px;"></i>
        {{ stock.createdBy ? stock.createdBy.email : 'Unknown' }}
    </span>
</td>
                            <td>
                                <div class="sm-actions">
                                    <a href="{{ path('app_dashboard_stock_show', {'id': stock.id}) }}" class="sm-btn view">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                    <a href="{{ path('app_dashboard_stock_edit', {'id': stock.id}) }}" class="sm-btn edit">
                                        <i class="fas fa-pen"></i> Edit
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
