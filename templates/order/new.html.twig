{% extends 'base.html.twig' %}

{% block title %}Create New Order
{% endblock %}

{% block stylesheets %}
	<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
	<style>:root
	{
		--brown-dark: #3e1f0d;
		--brown-mid: #6d4c41;
		--brown-acc: #8B5E3C;
		--brown-light: #c49a6c;
		--cream: #faf7f4;
		--cream2: #f3ece4;
		--white: #ffffff;
		--text: #2b1a0f;
		--muted: #9e8070;
	}

	body {
		font-family: 'DM Sans', sans-serif;
		background: var(--cream);
		color: var(--text);
	}

	.on-wrap {
		padding: 32px 36px;
	}

	/* ── ALERT ── */
	.on-alert {
		padding: 14px 20px;
		border-radius: 12px;
		margin-bottom: 20px;
		font-size: 14px;
		font-weight: 500;
		display: flex;
		align-items: center;
		gap: 10px;
		background: #ffebee;
		color: #c62828;
		border-left: 4px solid #f44336;
	}

	/* ── HEADER ── */
	.on-header {
		background: var(--brown-dark);
		border-radius: 18px;
		padding: 28px 32px;
		margin-bottom: 24px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
		overflow: hidden;
	}
	.on-header::before {
		content: '';
		position: absolute;
		top: -60px;
		right: -60px;
		width: 200px;
		height: 200px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.04);
	}
	.on-header h1 {
		font-family: 'Playfair Display', serif;
		font-size: 24px;
		color: #fff;
		margin: 0 0 4px;
		font-weight: 700;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.on-header p {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.55);
		margin: 0;
	}
	.on-back {
		background: rgba(255, 255, 255, 0.1);
		border: 1.5px solid rgba(255, 255, 255, 0.15);
		color: #fff;
		padding: 10px 22px;
		border-radius: 30px;
		text-decoration: none;
		font-size: 13px;
		font-weight: 600;
		display: flex;
		align-items: center;
		gap: 8px;
		position: relative;
		z-index: 1;
		transition: background 0.2s;
	}
	.on-back:hover {
		background: rgba(255, 255, 255, 0.18);
		color: #fff;
	}

	/* ── POS GRID ── */
	.on-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 20px;
	}

	/* ── CARDS ── */
	.on-card {
		background: var(--white);
		border-radius: 16px;
		padding: 26px 28px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
	}
	.on-card-title {
		font-family: 'Playfair Display', serif;
		font-size: 17px;
		font-weight: 700;
		color: var(--text);
		margin-bottom: 20px;
		padding-bottom: 14px;
		border-bottom: 1.5px solid var(--cream2);
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.on-card-title i {
		color: var(--brown-acc);
	}

	/* customer select */
	.on-label {
		display: flex;
		align-items: center;
		gap: 7px;
		font-size: 13px;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 8px;
	}
	.on-label i {
		color: var(--brown-light);
	}
	.on-select {
		width: 100%;
		padding: 13px 16px;
		border: 1.5px solid var(--cream2);
		border-radius: 10px;
		font-size: 14px;
		font-family: 'DM Sans', sans-serif;
		color: var(--text);
		background: var(--cream);
		outline: none;
		transition: border-color 0.2s;
		margin-bottom: 20px;
		appearance: none;
	}
	.on-select:focus {
		border-color: var(--brown-acc);
		background: var(--white);
	}

	/* products grid */
	.on-products {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 12px;
		max-height: 420px;
		overflow-y: auto;
		padding-right: 4px;
	}
	.on-products::-webkit-scrollbar {
		width: 4px;
	}
	.on-products::-webkit-scrollbar-track {
		background: var(--cream2);
		border-radius: 4px;
	}
	.on-products::-webkit-scrollbar-thumb {
		background: var(--brown-light);
		border-radius: 4px;
	}

	.on-prod-card {
		border: 1.5px solid var(--cream2);
		border-radius: 14px;
		padding: 16px;
		cursor: pointer;
		transition: all 0.2s;
		background: var(--cream);
	}
	.on-prod-card:hover {
		border-color: var(--brown-acc);
		background: #fdf5ee;
	}
	.on-prod-card.selected {
		border-color: var(--brown-dark);
		background: var(--cream2);
	}
	.on-prod-name {
		font-weight: 700;
		color: var(--text);
		font-size: 13px;
		margin-bottom: 4px;
	}
	.on-prod-price {
		color: var(--brown-acc);
		font-size: 13px;
		font-weight: 700;
		margin-bottom: 10px;
		font-family: 'Playfair Display', serif;
	}
	.on-prod-qty {
		display: none;
		align-items: center;
		gap: 8px;
		margin-top: 8px;
	}
	.on-prod-qty label {
		font-size: 11px;
		color: var(--muted);
		font-weight: 600;
	}
	.on-qty-input {
		width: 56px;
		padding: 5px 8px;
		border: 1.5px solid var(--cream2);
		border-radius: 6px;
		font-size: 13px;
		text-align: center;
		font-family: 'DM Sans', sans-serif;
		background: var(--white);
		outline: none;
		color: var(--text);
	}
	.on-qty-input:focus {
		border-color: var(--brown-acc);
	}

	/* nutrition pills on product card */
	.on-prod-nut {
		display: flex;
		flex-wrap: wrap;
		gap: 4px;
		margin-bottom: 8px;
	}
	.on-prod-nut span {
		font-size: 10px;
		font-weight: 700;
		background: rgba(139, 94, 60, 0.1);
		color: var(--brown-acc);
		padding: 2px 7px;
		border-radius: 10px;
	}

	/* ── ORDER SUMMARY ── */
	.on-summary-card {
		background: var(--white);
		border-radius: 16px;
		padding: 26px 28px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
		position: sticky;
		top: 20px;
	}

	.on-items {
		min-height: 120px;
		max-height: 300px;
		overflow-y: auto;
		margin-bottom: 16px;
	}
	.on-item {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		padding: 10px 0;
		border-bottom: 1.5px solid var(--cream2);
		font-size: 13px;
	}
	.on-item:last-child {
		border-bottom: none;
	}
	.on-item-name {
		font-weight: 600;
		color: var(--text);
		margin-bottom: 2px;
	}
	.on-item-sub {
		font-size: 11px;
		color: var(--muted);
	}
	.on-item-price {
		font-weight: 700;
		color: var(--brown-dark);
		font-family: 'Playfair Display', serif;
		font-size: 14px;
	}
	.on-empty-msg {
		text-align: center;
		padding: 24px 0;
		color: var(--muted);
		font-size: 13px;
	}

	.on-total-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 16px 0;
		border-top: 2px solid var(--cream2);
		margin-top: 8px;
	}
	.on-total-label {
		font-weight: 700;
		font-size: 14px;
		color: var(--text);
	}
	.on-total-value {
		font-family: 'Playfair Display', serif;
		font-size: 24px;
		font-weight: 700;
		color: var(--brown-dark);
	}

	.on-submit-btn {
		width: 100%;
		padding: 14px;
		background: var(--brown-dark);
		color: #fff;
		border: none;
		border-radius: 40px;
		font-size: 15px;
		font-weight: 700;
		cursor: pointer;
		font-family: 'DM Sans', sans-serif;
		transition: background 0.2s;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		margin-top: 12px;
	}
	.on-submit-btn:hover {
		background: var(--brown-acc);
	}
	.on-cancel-btn {
		width: 100%;
		padding: 12px;
		background: transparent;
		color: var(--muted);
		border: 2px solid var(--cream2);
		border-radius: 40px;
		font-size: 14px;
		font-weight: 700;
		cursor: pointer;
		font-family: 'DM Sans', sans-serif;
		transition: border-color 0.2s;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		margin-top: 8px;
		text-decoration: none;
	}
	.on-cancel-btn:hover {
		border-color: var(--brown-light);
		color: var(--text);
	}

	@media(max-width: 1024px) {
		.on-grid {
			grid-template-columns: 1fr;
		}
	}
</style>{% endblock %}{% block body %}
<div
	class="on-wrap">

	{# ── ALERTS ── #}
	{% for message in app.flashes('error') %}
		<div class="on-alert">
			<i class="fas fa-exclamation-circle"></i>
			{{ message }}</div>
	{% endfor %}

	{# ── HEADER ── #}
	<div class="on-header">
		<div>
			<h1>
				<i class="fas fa-plus-circle"></i>
				Create New Order</h1>
			<p>Select products and customer to create a new order.</p>
		</div>
		<a href="{{ path('app_order_index') }}" class="on-back">
			<i class="fas fa-arrow-left"></i>
			Back to Orders
		</a>
	</div>

	<form method="post" id="orderForm">
		<div
			class="on-grid">

			{# ── PRODUCTS SECTION ── #}
			<div class="on-card">
				<div class="on-card-title">
					<i class="fas fa-coffee"></i>
					Select Products
				</div>

				<label class="on-label" for="customer_id">
					<i class="fas fa-user"></i>
					Customer
				</label>
				<select name="customer_id" id="customer_id" class="on-select" required>
					<option value="">— Select Customer —</option>
					{% for customer in customers %}
						<option value="{{ customer.id }}">{{ customer.name }}
							({{ customer.email }})</option>
					{% endfor %}
				</select>

				<label class="on-label" for="payment_method">
					<i class="fas fa-credit-card"></i>
					Payment Method
				</label>
				<select name="payment_method" id="payment_method" class="on-select" required>
					<option value="cash">Cash</option>
					<option value="gcash">GCash</option>
					<option value="card">Card</option>
				</select>

				<div id="gcashWrap" style="display:none; margin-top:-6px; margin-bottom:14px;">
					<label class="on-label" for="gcash_number">
						<i class="fas fa-mobile-alt"></i>
						GCash Number
					</label>
					<input type="text" id="gcash_number" name="gcash_number" class="on-select" placeholder="09XXXXXXXXX" inputmode="numeric"/>
				</div>

				<div id="cardWrap" style="display:none; margin-top:-6px; margin-bottom:14px;">
					<label class="on-label" for="card_type">
						<i class="fas fa-id-card"></i>
						Card Type
					</label>
					<select id="card_type" name="card_type" class="on-select">
						<option value="">— Select Card Type —</option>
						<option value="visa">VISA</option>
						<option value="mastercard">Mastercard</option>
						<option value="amex">AMEX</option>
						<option value="jcb">JCB</option>
					</select>
				</div>

				<div class="on-card-title" style="margin-top:4px;">
					<i class="fas fa-list"></i>
					Available Products
				</div>

				<div class="on-products" id="productsGrid">
					{% for product in products %}
						<div class="on-prod-card" data-id="{{ product.id }}" data-name="{{ product.name }}" data-price="{{ product.price }}">
							<div class="on-prod-name">{{ product.name }}</div>
							<div class="on-prod-price">₱{{ product.price|number_format(2) }}</div>
							{% if product.calories is defined %}
								<div class="on-prod-nut">
									{% if product.calories %}
										<span>
											<i class="fas fa-fire" style="font-size:9px;"></i>
											{{ product.calories }}kcal</span>
									{% endif %}
									{% if product.caffeineMg %}
										<span>
											<i class="fas fa-bolt" style="font-size:9px;"></i>
											{{ product.caffeineMg }}mg</span>
									{% endif %}
								</div>
							{% endif %}
							<div class="on-prod-qty">
								<label>Qty:</label>
								<input type="number" class="on-qty-input" min="1" value="1" data-product="{{ product.id }}">
								<input type="hidden" name="products[{{ loop.index0 }}][id]" value="">
								<input type="hidden" name="products[{{ loop.index0 }}][quantity]" value="">
							</div>
						</div>
					{% endfor %}
				</div>
			</div>

			{# ── ORDER SUMMARY ── #}
			<div class="on-summary-card">
				<div class="on-card-title">
					<i class="fas fa-receipt"></i>
					Order Summary
				</div>

				<div class="on-items" id="orderItems">
					<div class="on-empty-msg">
						<i class="fas fa-shopping-bag" style="font-size:28px; opacity:.2; display:block; margin-bottom:8px;"></i>
						No items selected
					</div>
				</div>

				<div class="on-total-row">
					<span class="on-total-label">Total</span>
					<span class="on-total-value" id="totalAmount">₱0.00</span>
				</div>

				<button type="submit" class="on-submit-btn">
					<i class="fas fa-check"></i>
					Complete Order
				</button>
				<a href="{{ path('app_order_index') }}" class="on-cancel-btn">
					<i class="fas fa-times"></i>
					Cancel
				</a>
			</div>

		</div>
	</form>

</div>

<script>
	let selectedProducts = [];
const paymentMethodSelect = document.getElementById('payment_method');
const gcashWrap = document.getElementById('gcashWrap');
const cardWrap = document.getElementById('cardWrap');
const gcashInput = document.getElementById('gcash_number');
const cardTypeSelect = document.getElementById('card_type');

function syncPaymentFields() {
const method = (paymentMethodSelect ?. value || 'cash').toLowerCase();
const isGcash = method === 'gcash';
const isCard = method === 'card';

if (gcashWrap) 
gcashWrap.style.display = isGcash ? 'block' : 'none';

if (cardWrap) 
cardWrap.style.display = isCard ? 'block' : 'none';

if (gcashInput) {
gcashInput.required = isGcash;
if (! isGcash) 
gcashInput.value = '';

}
if (cardTypeSelect) {
cardTypeSelect.required = isCard;
if (! isCard) 
cardTypeSelect.value = '';

}
}

if (paymentMethodSelect) {
paymentMethodSelect.addEventListener('change', syncPaymentFields);
syncPaymentFields();
}

document.querySelectorAll('.on-prod-card').forEach(card => {
card.addEventListener('click', function (e) {
if (e.target.classList.contains('on-qty-input')) 
return;



const productId = this.dataset.id;
const productName = this.dataset.name;
const productPrice = parseFloat(this.dataset.price);

if (this.classList.contains('selected')) {
this.classList.remove('selected');
this.querySelector('.on-prod-qty').style.display = 'none';
selectedProducts = selectedProducts.filter(p => p.id !== productId);
} else {
this.classList.add('selected');
this.querySelector('.on-prod-qty').style.display = 'flex';
selectedProducts.push({id: productId, name: productName, price: productPrice, quantity: 1});
} updateOrderSummary();
});

const qtyInput = card.querySelector('.on-qty-input');
if (qtyInput) {
qtyInput.addEventListener('input', function () {
const productId = card.dataset.id;
const product = selectedProducts.find(p => p.id === productId);
if (product) {
product.quantity = parseInt(this.value) || 1;
updateOrderSummary();
}
});
}
});

function updateOrderSummary() {
const orderItems = document.getElementById('orderItems');
const totalAmount = document.getElementById('totalAmount');

if (selectedProducts.length === 0) {
orderItems.innerHTML = `<div class="on-empty-msg"><i class="fas fa-shopping-bag" style="font-size:28px;opacity:.2;display:block;margin-bottom:8px;"></i>No items selected</div>`;
totalAmount.textContent = '₱0.00';
return;
}

let html = '';
let total = 0;

selectedProducts.forEach((product, index) => {
const itemTotal = product.price * product.quantity;
total += itemTotal;
html += `
                <div class="on-item">
                    <div>
                        <div class="on-item-name">${
product.name
}</div>
                        <div class="on-item-sub">₱${
product.price.toFixed(2)
} × ${
product.quantity
}</div>
                    </div>
                    <div class="on-item-price">₱${
itemTotal.toFixed(2)
}</div>
                </div>
            `;
const idInput = document.querySelector (`input[name="products[${index}][id]"]`);
const qtyInput = document.querySelector (`input[name="products[${index}][quantity]"]`);
if (idInput) 
idInput.value = product.id;


if (qtyInput) 
qtyInput.value = product.quantity;


});

orderItems.innerHTML = html;
totalAmount.textContent = '₱' + total.toFixed(2);
}
</script>{% endblock %}
