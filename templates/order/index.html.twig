{% extends 'base.html.twig' %}

{% block title %}Orders Management
{% endblock %}

{% block stylesheets %}
	<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
	<style>:root
	{
		--brown-dark: #3e1f0d;
		--brown-mid: #6d4c41;
		--brown-acc: #8B5E3C;
		--brown-light: #c49a6c;
		--cream: #faf7f4;
		--cream2: #f3ece4;
		--white: #ffffff;
		--text: #2b1a0f;
		--muted: #9e8070;
	}

	body {
		font-family: 'DM Sans', sans-serif;
		background: var(--cream);
		color: var(--text);
	}

	.oi-wrap {
		padding: 32px 36px;
	}

	/* ── ALERTS ── */
	.oi-alert {
		padding: 14px 20px;
		border-radius: 12px;
		margin-bottom: 20px;
		font-size: 14px;
		font-weight: 500;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.oi-alert.success {
		background: #e8f5e9;
		color: #2e7d32;
		border-left: 4px solid #4caf50;
	}
	.oi-alert.error {
		background: #ffebee;
		color: #c62828;
		border-left: 4px solid #f44336;
	}

	/* ── HEADER ── */
	.oi-header {
		background: var(--brown-dark);
		border-radius: 18px;
		padding: 28px 32px;
		margin-bottom: 28px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
		overflow: hidden;
	}
	.oi-header::before {
		content: '';
		position: absolute;
		top: -60px;
		right: -60px;
		width: 200px;
		height: 200px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.04);
	}
	.oi-header h1 {
		font-family: 'Playfair Display', serif;
		font-size: 24px;
		color: #fff;
		margin: 0 0 4px;
		font-weight: 700;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.oi-header p {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.55);
		margin: 0;
	}
	.oi-add-btn {
		background: rgba(255, 255, 255, 0.12);
		border: 1.5px solid rgba(255, 255, 255, 0.2);
		color: #fff;
		padding: 11px 24px;
		border-radius: 30px;
		text-decoration: none;
		font-size: 13px;
		font-weight: 700;
		transition: background 0.2s;
		display: flex;
		align-items: center;
		gap: 8px;
		position: relative;
		z-index: 1;
	}
	.oi-add-btn:hover {
		background: rgba(255, 255, 255, 0.2);
		color: #fff;
	}

	/* ── STATS ── */
	.oi-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
		margin-bottom: 24px;
	}
	.oi-stat {
		background: var(--white);
		border-radius: 16px;
		padding: 22px;
		display: flex;
		align-items: center;
		gap: 16px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
		border-left: 4px solid var(--brown-acc);
		transition: transform 0.3s, box-shadow 0.3s;
	}
	.oi-stat:hover {
		transform: translateY(-4px);
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.09);
	}
	.oi-stat.pending {
		border-left-color: #f57c00;
	}
	.oi-stat.completed {
		border-left-color: #2e7d32;
	}
	.oi-stat.cancelled {
		border-left-color: #c62828;
	}
	.oi-stat-icon {
		width: 50px;
		height: 50px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 20px;
		flex-shrink: 0;
	}
	.oi-stat.pending .oi-stat-icon {
		background: #fff3e0;
		color: #f57c00;
	}
	.oi-stat.completed .oi-stat-icon {
		background: #e8f5e9;
		color: #2e7d32;
	}
	.oi-stat.cancelled .oi-stat-icon {
		background: #ffebee;
		color: #c62828;
	}
	.oi-stat-label {
		font-size: 11px;
		color: var(--muted);
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		margin-bottom: 4px;
	}
	.oi-stat-value {
		font-family: 'Playfair Display', serif;
		font-size: 28px;
		font-weight: 700;
		color: var(--text);
		line-height: 1;
	}

	/* ── TABLE CARD ── */
	.oi-card {
		background: var(--white);
		border-radius: 16px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
		overflow: hidden;
	}
	.oi-card-head {
		padding: 22px 28px;
		border-bottom: 1.5px solid var(--cream2);
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.oi-card-head h3 {
		font-family: 'Playfair Display', serif;
		font-size: 17px;
		font-weight: 700;
		color: var(--text);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.oi-card-head h3 i {
		color: var(--brown-acc);
	}
	.oi-count {
		font-size: 13px;
		color: var(--muted);
		font-weight: 500;
	}

	/* ── TABLE ── */
	table.oi-table {
		width: 100%;
		border-collapse: collapse;
	}
	table.oi-table thead th {
		padding: 12px 18px;
		text-align: left;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: var(--muted);
		background: var(--cream);
		border-bottom: 2px solid var(--cream2);
	}
	table.oi-table tbody td {
		padding: 16px 18px;
		font-size: 13px;
		color: var(--text);
		border-bottom: 1.5px solid var(--cream2);
		vertical-align: middle;
	}
	table.oi-table tbody tr:last-child td {
		border-bottom: none;
	}
	table.oi-table tbody tr:hover td {
		background: var(--cream);
	}

	/* order number */
	.oi-order-num {
		font-weight: 700;
		color: var(--brown-dark);
		font-size: 14px;
	}

	/* customer cell */
	.oi-cust-cell {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.oi-cust-avatar {
		width: 34px;
		height: 34px;
		border-radius: 50%;
		background: var(--cream2);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--brown-mid);
		font-size: 13px;
		flex-shrink: 0;
	}

	/* total */
	.oi-total {
		font-family: 'Playfair Display', serif;
		font-size: 15px;
		font-weight: 700;
		color: var(--brown-dark);
	}

	/* status badges */
	.oi-badge {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 4px 12px;
		border-radius: 20px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}
	.oi-badge.pending {
		background: #fff3e0;
		color: #f57c00;
	}
	.oi-badge.completed {
		background: #e8f5e9;
		color: #2e7d32;
	}
	.oi-badge.cancelled {
		background: #ffebee;
		color: #c62828;
	}

	/* action buttons */
	.oi-actions {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
	}
	.oi-btn {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 7px 14px;
		border-radius: 20px;
		font-size: 12px;
		font-weight: 700;
		text-decoration: none;
		border: none;
		cursor: pointer;
		font-family: 'DM Sans', sans-serif;
		transition: opacity 0.2s, transform 0.2s;
	}
	.oi-btn:hover {
		opacity: .85;
		transform: translateY(-1px);
	}
	.oi-btn.view {
		background: var(--cream2);
		color: var(--brown-dark);
	}
	.oi-btn.edit {
		background: #fff3e0;
		color: #e65100;
	}
	.oi-btn.delete {
		background: #ffebee;
		color: #c62828;
	}
	.oi-btn-form {
		display: inline;
	}

	/* empty */
	.oi-empty {
		text-align: center;
		padding: 60px 20px;
		color: var(--muted);
	}
	.oi-empty i {
		font-size: 48px;
		opacity: .3;
		margin-bottom: 16px;
		display: block;
	}
	.oi-empty p {
		font-size: 15px;
		margin: 0;
	}
</style>{% endblock %}{% block body %}
<div
	class="oi-wrap">

	{# ── ALERTS ── #}
	{% for message in app.flashes('success') %}
		<div class="oi-alert success">
			<i class="fas fa-check-circle"></i>
			{{ message }}</div>
	{% endfor %}
	{% for message in app.flashes('error') %}
		<div class="oi-alert error">
			<i class="fas fa-exclamation-circle"></i>
			{{ message }}</div>
	{% endfor %}

	{# ── HEADER ── #}
	<div class="oi-header">
		<div>
			<h1>
				<i class="fas fa-shopping-bag"></i>
				Orders Management</h1>
			<p>View and manage all customer orders.</p>
		</div>
		<a href="{{ path('app_order_new') }}" class="oi-add-btn">
			<i class="fas fa-plus"></i>
			Create New Order
		</a>
	</div>

	{# ── STATS ── #}
	{% set pendingCount   = orders|filter(o => o.status == 'pending')|length %}
	{% set completedCount = orders|filter(o => o.status == 'completed')|length %}
	{% set cancelledCount = orders|filter(o => o.status == 'cancelled')|length %}

	<div class="oi-stats">
		<div class="oi-stat pending">
			<div class="oi-stat-icon">
				<i class="fas fa-clock"></i>
			</div>
			<div>
				<div class="oi-stat-label">Pending</div>
				<div class="oi-stat-value">{{ pendingCount }}</div>
			</div>
		</div>
		<div class="oi-stat completed">
			<div class="oi-stat-icon">
				<i class="fas fa-check-circle"></i>
			</div>
			<div>
				<div class="oi-stat-label">Completed</div>
				<div class="oi-stat-value">{{ completedCount }}</div>
			</div>
		</div>
		<div class="oi-stat cancelled">
			<div class="oi-stat-icon">
				<i class="fas fa-times-circle"></i>
			</div>
			<div>
				<div class="oi-stat-label">Cancelled</div>
				<div class="oi-stat-value">{{ cancelledCount }}</div>
			</div>
		</div>
	</div>

	{# ── TABLE ── #}
	<div class="oi-card">
		<div class="oi-card-head">
			<h3>
				<i class="fas fa-list"></i>
				All Orders</h3>
			<span class="oi-count">{{ orders|length }}
				order{{ orders|length != 1 ? 's' : '' }}
				found</span>
		</div>

		{% if orders is empty %}
			<div class="oi-empty">
				<i class="fas fa-shopping-bag"></i>
				<p>No orders found in the system.</p>
			</div>
		{% else %}
			<div style="overflow-x:auto;">
				<table class="oi-table">
					<thead>
						<tr>
							<th>Order #</th>
							<th>Customer</th>
							<th>Total</th>
							<th>Payment</th>
							<th>Status</th>
							<th>Date</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for order in orders %}
							<tr>
								<td>
									<span class="oi-order-num">#{{ order.orderNumber }}</span>
								</td>
								<td>
									<div class="oi-cust-cell">
										<div class="oi-cust-avatar">
											<i class="fas fa-user" style="font-size:12px;"></i>
										</div>
										{{ order.customer.name }}
									</div>
								</td>
								<td>
									<span class="oi-total">₱{{ order.total|number_format(2) }}</span>
								</td>
								<td>
									<span style="font-size:12px; font-weight:700; color:var(--brown-dark); text-transform:uppercase; display:block;">
										{{ order.paymentMethod|default('cash') }}
									</span>
									{% if order.paymentMethod == 'gcash' and order.gcashNumber %}
										<span style="font-size:11px; color:var(--muted);">{{ order.gcashNumber }}</span>
									{% elseif order.paymentMethod == 'card' and order.cardType %}
										<span style="font-size:11px; color:var(--muted); text-transform:uppercase;">{{ order.cardType }}</span>
									{% endif %}
								</td>
								<td>
									{% if order.status == 'pending' %}
										<span class="oi-badge pending">
											<i class="fas fa-clock"></i>
											Pending</span>
									{% elseif order.status == 'completed' %}
										<span class="oi-badge completed">
											<i class="fas fa-check-circle"></i>
											Completed</span>
									{% else %}
										<span class="oi-badge cancelled">
											<i class="fas fa-times-circle"></i>
											Cancelled</span>
									{% endif %}
								</td>
								<td>
									<span style="color:var(--muted); font-size:12px;">
										<i class="far fa-calendar" style="margin-right:4px;"></i>
										{{ order.createdAt|date('M d, Y') }}<br>
										<small>{{ order.createdAt|date('h:i A') }}</small>
									</span>
								</td>
								<td>
									<div class="oi-actions">
										<a href="{{ path('app_order_show', {'id': order.id}) }}" class="oi-btn view">
											<i class="fas fa-eye"></i>
											View
										</a>
										{% if order.status == 'pending' %}
											<a href="{{ path('app_order_edit', {'id': order.id}) }}" class="oi-btn edit">
												<i class="fas fa-pen"></i>
												Edit
											</a>
											<form method="post" action="{{ path('app_order_cancel', {'id': order.id}) }}" class="oi-btn-form" onsubmit="return confirm('Cancel this pending order?');">
												<input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ order.id) }}">
												<button class="oi-btn delete">
													<i class="fas fa-ban"></i>
													Cancel
												</button>
											</form>
											<form method="post" action="{{ path('app_order_delete', {'id': order.id}) }}" class="oi-btn-form" onsubmit="return confirm('Are you sure you want to delete this order?');">
												<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
												<button class="oi-btn delete">
													<i class="fas fa-trash"></i>
													Delete
												</button>
											</form>
										{% endif %}
									</div>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% endif %}
	</div>

</div>{% endblock %}
