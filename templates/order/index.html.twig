{% extends 'base.html.twig' %}

{% block title %}Orders Management
{% endblock %}

{% block stylesheets %}
	<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
	<style>:root
	{
		--brown-dark: #c2410c;
		--brown-mid: #ea580c;
		--brown-acc: #f97316;
		--brown-light: #fdba74;
		--cream: #fff7ed;
		--cream2: #ffedd5;
		--white: #ffffff;
		--text: #431407;
		--muted: #b45309;
	}

	body {
		font-family: 'DM Sans', sans-serif;
		background: var(--cream);
		color: var(--text);
	}

	.oi-wrap {
		padding: 32px 36px;
	}

	/* ── ALERTS ── */
	.oi-alert {
		padding: 14px 20px;
		border-radius: 12px;
		margin-bottom: 20px;
		font-size: 14px;
		font-weight: 500;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.oi-alert.success {
		background: #e8f5e9;
		color: #2e7d32;
		border-left: 4px solid #4caf50;
	}
	.oi-alert.error {
		background: #ffebee;
		color: #c62828;
		border-left: 4px solid #f44336;
	}

	@keyframes oi-row-highlight {
		from { background: #fff8e1; }
		to { background: transparent; }
	}
	tr.oi-row-new td {
		animation: oi-row-highlight 2.5s ease-out;
	}

	/* ── HEADER ── */
	.oi-header {
		background: var(--brown-dark);
		border-radius: 18px;
		padding: 28px 32px;
		margin-bottom: 28px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
		overflow: hidden;
	}
	.oi-header::before {
		content: '';
		position: absolute;
		top: -60px;
		right: -60px;
		width: 200px;
		height: 200px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.04);
	}
	.oi-header h1 {
		font-family: 'Playfair Display', serif;
		font-size: 24px;
		color: #fff;
		margin: 0 0 4px;
		font-weight: 700;
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.oi-header p {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.55);
		margin: 0;
	}
	.oi-add-btn {
		background: rgba(255, 255, 255, 0.12);
		border: 1.5px solid rgba(255, 255, 255, 0.2);
		color: #fff;
		padding: 11px 24px;
		border-radius: 30px;
		text-decoration: none;
		font-size: 13px;
		font-weight: 700;
		transition: background 0.2s;
		display: flex;
		align-items: center;
		gap: 8px;
		position: relative;
		z-index: 1;
	}
	.oi-add-btn:hover {
		background: rgba(255, 255, 255, 0.2);
		color: #fff;
	}

	/* ── STATS ── */
	.oi-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
		margin-bottom: 24px;
	}
	.oi-stat {
		background: var(--white);
		border-radius: 16px;
		padding: 22px;
		display: flex;
		align-items: center;
		gap: 16px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
		border-left: 4px solid var(--brown-acc);
		transition: transform 0.3s, box-shadow 0.3s;
	}
	.oi-stat:hover {
		transform: translateY(-4px);
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.09);
	}
	.oi-stat.pending {
		border-left-color: #f57c00;
	}
	.oi-stat.completed {
		border-left-color: #2e7d32;
	}
	.oi-stat.cancelled {
		border-left-color: #c62828;
	}
	.oi-stat-icon {
		width: 50px;
		height: 50px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 20px;
		flex-shrink: 0;
	}
	.oi-stat.pending .oi-stat-icon {
		background: #fff3e0;
		color: #f57c00;
	}
	.oi-stat.completed .oi-stat-icon {
		background: #e8f5e9;
		color: #2e7d32;
	}
	.oi-stat.cancelled .oi-stat-icon {
		background: #ffebee;
		color: #c62828;
	}
	.oi-stat-label {
		font-size: 11px;
		color: var(--muted);
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		margin-bottom: 4px;
	}
	.oi-stat-value {
		font-family: 'Playfair Display', serif;
		font-size: 28px;
		font-weight: 700;
		color: var(--text);
		line-height: 1;
	}

	/* ── TABLE CARD ── */
	.oi-card {
		background: var(--white);
		border-radius: 16px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
		overflow: hidden;
	}
	.oi-card-head {
		padding: 22px 28px;
		border-bottom: 1.5px solid var(--cream2);
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.oi-card-head h3 {
		font-family: 'Playfair Display', serif;
		font-size: 17px;
		font-weight: 700;
		color: var(--text);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.oi-card-head h3 i {
		color: var(--brown-acc);
	}
	.oi-count {
		font-size: 13px;
		color: var(--muted);
		font-weight: 500;
	}

	/* ── TABLE ── */
	table.oi-table {
		width: 100%;
		border-collapse: collapse;
	}
	table.oi-table thead th {
		padding: 12px 18px;
		text-align: left;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: var(--muted);
		background: var(--cream);
		border-bottom: 2px solid var(--cream2);
	}
	table.oi-table tbody td {
		padding: 16px 18px;
		font-size: 13px;
		color: var(--text);
		border-bottom: 1.5px solid var(--cream2);
		vertical-align: middle;
	}
	table.oi-table tbody tr:last-child td {
		border-bottom: none;
	}
	table.oi-table tbody tr:hover td {
		background: var(--cream);
	}

	/* order number */
	.oi-order-num {
		font-weight: 700;
		color: var(--brown-dark);
		font-size: 14px;
	}

	/* customer cell */
	.oi-cust-cell {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.oi-cust-avatar {
		width: 34px;
		height: 34px;
		border-radius: 50%;
		background: var(--cream2);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--brown-mid);
		font-size: 13px;
		flex-shrink: 0;
	}

	/* total */
	.oi-total {
		font-family: 'Playfair Display', serif;
		font-size: 15px;
		font-weight: 700;
		color: var(--brown-dark);
	}

	/* status badges */
	.oi-badge {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 4px 12px;
		border-radius: 20px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}
	.oi-badge.pending {
		background: #fff3e0;
		color: #f57c00;
	}
	.oi-badge.completed {
		background: #e8f5e9;
		color: #2e7d32;
	}
	.oi-badge.cancelled {
		background: #ffebee;
		color: #c62828;
	}

	/* action buttons */
	.oi-actions {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
	}
	.oi-btn {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 7px 14px;
		border-radius: 20px;
		font-size: 12px;
		font-weight: 700;
		text-decoration: none;
		border: none;
		cursor: pointer;
		font-family: 'DM Sans', sans-serif;
		transition: opacity 0.2s, transform 0.2s;
	}
	.oi-btn:hover {
		opacity: .85;
		transform: translateY(-1px);
	}
	.oi-btn.view {
		background: var(--cream2);
		color: var(--brown-dark);
	}
	.oi-btn.edit {
		background: #fff3e0;
		color: #e65100;
	}
	.oi-btn.delete {
		background: #ffebee;
		color: #c62828;
	}
	.oi-btn-form {
		display: inline;
	}

	/* empty */
	.oi-empty {
		text-align: center;
		padding: 60px 20px;
		color: var(--muted);
	}
	.oi-empty i {
		font-size: 48px;
		opacity: .3;
		margin-bottom: 16px;
		display: block;
	}
	.oi-empty p {
		font-size: 15px;
		margin: 0;
	}
</style>{% endblock %}{% block body %}
<div
	class="oi-wrap">

	{# ── ALERTS ── #}
	{% for message in app.flashes('success') %}
		<div class="oi-alert success">
			<i class="fas fa-check-circle"></i>
			{{ message }}</div>
	{% endfor %}
	{% for message in app.flashes('error') %}
		<div class="oi-alert error">
			<i class="fas fa-exclamation-circle"></i>
			{{ message }}</div>
	{% endfor %}

	{# ── HEADER ── #}
	<div class="oi-header">
		<div>
			<h1>
				<i class="fas fa-shopping-bag"></i>
				Orders Management</h1>
			<p>View and manage all customer orders.
				<span id="oi-live-badge" style="display:inline-flex;align-items:center;gap:6px;margin-left:8px;font-size:12px;font-weight:600;color:#a8e6cf;">
					<i class="fas fa-circle" style="font-size:8px;"></i> Connecting…
				</span>
			</p>
		</div>
		<a href="{{ path('app_order_new') }}" class="oi-add-btn">
			<i class="fas fa-plus"></i>
			Create New Order
		</a>
	</div>

	{# ── STATS ── #}
	{% set pendingCount   = orders|filter(o => o.status == 'pending')|length %}
	{% set completedCount = orders|filter(o => o.status == 'completed')|length %}
	{% set cancelledCount = orders|filter(o => o.status == 'cancelled')|length %}

	<div class="oi-stats" id="oi-stats">
		<div class="oi-stat pending">
			<div class="oi-stat-icon">
				<i class="fas fa-clock"></i>
			</div>
			<div>
				<div class="oi-stat-label">Pending</div>
				<div class="oi-stat-value" id="oi-stat-pending">{{ pendingCount }}</div>
			</div>
		</div>
		<div class="oi-stat completed">
			<div class="oi-stat-icon">
				<i class="fas fa-check-circle"></i>
			</div>
			<div>
				<div class="oi-stat-label">Completed</div>
				<div class="oi-stat-value" id="oi-stat-completed">{{ completedCount }}</div>
			</div>
		</div>
		<div class="oi-stat cancelled">
			<div class="oi-stat-icon">
				<i class="fas fa-times-circle"></i>
			</div>
			<div>
				<div class="oi-stat-label">Cancelled</div>
				<div class="oi-stat-value" id="oi-stat-cancelled">{{ cancelledCount }}</div>
			</div>
		</div>
	</div>

	{# ── TABLE ── #}
	<div class="oi-card">
		<div class="oi-card-head">
			<h3>
				<i class="fas fa-list"></i>
				All Orders</h3>
			<span class="oi-count" id="oi-order-count">{{ orders|length }}
				order{{ orders|length != 1 ? 's' : '' }}
				found</span>
		</div>

		<div id="oi-empty" class="oi-empty" {% if orders is not empty %}style="display:none;"{% endif %}>
			<i class="fas fa-shopping-bag"></i>
			<p>No orders found in the system.</p>
		</div>

		<div id="oi-table-wrap" style="overflow-x:auto;{% if orders is empty %}display:none;{% endif %}">
			<table class="oi-table">
				<thead>
					<tr>
						<th>Order #</th>
						<th>Customer</th>
						<th>Total</th>
						<th>Payment</th>
						<th>Status</th>
						<th>Date</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody id="oi-orders-tbody">
					{% for order in orders %}
						{% include 'order/_row.html.twig' %}
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>

</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		(function () {
			const feedUrl = {{ path('app_order_feed')|json_encode|raw }};
			const rowUrlTemplate = {{ path('app_order_row', { id: 0 })|json_encode|raw }}.replace('/0', '/');
			const pageLoadedAt = {{ pageLoadedAt|json_encode|raw }};
			const knownOrderIds = new Set(
				Array.from(document.querySelectorAll('#oi-orders-tbody tr[data-order-id]'))
					.map((row) => parseInt(row.dataset.orderId, 10))
					.filter((id) => !Number.isNaN(id))
			);

			const tbody = document.getElementById('oi-orders-tbody');
			const emptyEl = document.getElementById('oi-empty');
			const tableWrap = document.getElementById('oi-table-wrap');
			const countEl = document.getElementById('oi-order-count');
			const pendingEl = document.getElementById('oi-stat-pending');
			const completedEl = document.getElementById('oi-stat-completed');
			const cancelledEl = document.getElementById('oi-stat-cancelled');

			let lastSyncAt = pageLoadedAt;
			const liveBadge = document.getElementById('oi-live-badge');

			function setLiveBadge(state) {
				if (!liveBadge) return;
				const styles = {
					live: { color: '#a8e6cf', text: '● Live updates active' },
					connecting: { color: '#fde68a', text: '○ Connecting…' },
					polling: { color: '#c4b5fd', text: '○ Polling for new orders…' },
					offline: { color: '#fca5a5', text: '○ Offline — refresh page' },
				};
				const s = styles[state] || styles.connecting;
				liveBadge.style.color = s.color;
				liveBadge.innerHTML = s.text;
			}

			function updateOrderCount() {
				const count = tbody ? tbody.querySelectorAll('tr[data-order-id]').length : 0;
				if (countEl) {
					countEl.textContent = count + ' order' + (count === 1 ? '' : 's') + ' found';
				}
				if (emptyEl && tableWrap) {
					const isEmpty = count === 0;
					emptyEl.style.display = isEmpty ? '' : 'none';
					tableWrap.style.display = isEmpty ? 'none' : '';
				}
			}

			function bumpStat(status) {
				if (status === 'pending' && pendingEl) {
					pendingEl.textContent = String(parseInt(pendingEl.textContent, 10) + 1);
				}
				if (status === 'completed' && completedEl) {
					completedEl.textContent = String(parseInt(completedEl.textContent, 10) + 1);
				}
				if (status === 'cancelled' && cancelledEl) {
					cancelledEl.textContent = String(parseInt(cancelledEl.textContent, 10) + 1);
				}
			}

			function adjustStat(fromStatus, delta) {
				const map = {
					pending: pendingEl,
					completed: completedEl,
					cancelled: cancelledEl,
				};
				const el = map[fromStatus];
				if (!el) {
					return;
				}
				el.textContent = String(Math.max(0, parseInt(el.textContent, 10) + delta));
			}

			function showLiveToast(message) {
				let toast = document.getElementById('oi-live-toast');
				if (!toast) {
					toast = document.createElement('div');
					toast.id = 'oi-live-toast';
					toast.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:9999;background:#c2410c;color:#fff;padding:14px 20px;border-radius:12px;font-size:14px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,.2);display:flex;align-items:center;gap:10px;transition:opacity .3s;';
					document.body.appendChild(toast);
				}
				toast.innerHTML = '<i class="fas fa-bell"></i> ' + message;
				toast.style.opacity = '1';
				clearTimeout(toast._hideTimer);
				toast._hideTimer = setTimeout(() => {
					toast.style.opacity = '0';
				}, 4000);
			}

			async function fetchOrderRow(orderId) {
				const response = await fetch(rowUrlTemplate + orderId, {
					headers: { 'X-Requested-With': 'XMLHttpRequest' },
					credentials: 'same-origin',
				});
				if (!response.ok) {
					throw new Error('Failed to load order row');
				}
				return response.text();
			}

			async function insertOrderRow(orderId) {
				if (!tbody || knownOrderIds.has(orderId)) {
					return;
				}
				const html = await fetchOrderRow(orderId);
				const template = document.createElement('template');
				template.innerHTML = html.trim();
				const row = template.content.querySelector('tr[data-order-id]');
				if (!row) {
					return;
				}
				row.classList.add('oi-row-new');
				tbody.insertBefore(row, tbody.firstChild);
				knownOrderIds.add(orderId);
				bumpStat('pending');
				updateOrderCount();
				showLiveToast('New order received');
			}

			async function refreshOrderRow(orderId, previousStatus) {
				if (!tbody) {
					return;
				}
				const existing = tbody.querySelector('tr[data-order-id="' + orderId + '"]');
				if (!existing) {
					return await insertOrderRow(orderId);
				}
				const html = await fetchOrderRow(orderId);
				const template = document.createElement('template');
				template.innerHTML = html.trim();
				const row = template.content.querySelector('tr[data-order-id]');
				if (!row) {
					return;
				}
				const newStatus = statusFromRow(row);
				if (previousStatus && previousStatus !== newStatus) {
					adjustStat(previousStatus, -1);
					bumpStat(newStatus);
				}
				existing.replaceWith(row);
			}

			function statusFromRow(row) {
				if (!row) {
					return null;
				}
				if (row.querySelector('.oi-badge.completed')) {
					return 'completed';
				}
				if (row.querySelector('.oi-badge.cancelled')) {
					return 'cancelled';
				}
				return 'pending';
			}

			async function handleOrderEvent(payload) {
				if (!payload?.orderId) {
					return;
				}

				if (payload.type === 'deleted') {
					const existing = tbody?.querySelector('tr[data-order-id="' + payload.orderId + '"]');
					if (existing) {
						const previousStatus = statusFromRow(existing);
						if (previousStatus) adjustStat(previousStatus, -1);
						existing.remove();
						knownOrderIds.delete(payload.orderId);
						updateOrderCount();
					}
					return;
				}

				if (payload.type === 'created') {
					await insertOrderRow(payload.orderId);
					return;
				}
				if (payload.type === 'updated') {
					const existing = tbody?.querySelector('tr[data-order-id="' + payload.orderId + '"]');
					const previousStatus = statusFromRow(existing);
					await refreshOrderRow(payload.orderId, previousStatus);
				}
			}

			async function pollFeed() {
				try {
					const sinceDate = new Date(lastSyncAt);
					sinceDate.setSeconds(sinceDate.getSeconds() - 3);
					const response = await fetch(feedUrl + '?since=' + encodeURIComponent(sinceDate.toISOString()), {
						headers: { 'X-Requested-With': 'XMLHttpRequest' },
						credentials: 'same-origin',
					});
					if (!response.ok) {
						return;
					}
					const data = await response.json();
					for (const item of data.orders || []) {
						await handleOrderEvent(item);
					}
					lastSyncAt = new Date().toISOString();
				} catch (e) {
					console.warn('Order feed poll failed', e);
				}
			}

			try {
				CafeRealtime.connect('/orders', (_topic, payload) => handleOrderEvent(payload), (status) => {
					if (status === 'subscribed') {
						setLiveBadge('live');
					} else if (status === 'connected' || status === 'connecting') {
						setLiveBadge('connecting');
					} else if (status === 'disconnected' || status === 'error') {
						setLiveBadge('polling');
					}
				});
			} catch (e) {
				console.warn('WebSocket unavailable, using polling only', e);
				setLiveBadge('polling');
			}

			setInterval(pollFeed, 3000);
			setTimeout(pollFeed, 800);
		})();
	</script>
{% endblock %}
