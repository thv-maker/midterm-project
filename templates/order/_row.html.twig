<tr data-order-id="{{ order.id }}">
	<td>
		<span class="oi-order-num">#{{ order.orderNumber }}</span>
	</td>
	<td>
		<div class="oi-cust-cell">
			<div class="oi-cust-avatar">
				<i class="fas fa-user" style="font-size:12px;"></i>
			</div>
			{{ order.customer.name }}
		</div>
	</td>
	<td>
		<span class="oi-total">₱{{ order.total|number_format(2) }}</span>
	</td>
	<td>
		<span style="font-size:12px; font-weight:700; color:var(--brown-dark); text-transform:uppercase; display:block;">
			{{ order.paymentMethod|default('cash') }}
		</span>
		{% if order.paymentMethod == 'gcash' and order.gcashNumber %}
			<span style="font-size:11px; color:var(--muted);">{{ order.gcashNumber }}</span>
		{% elseif order.paymentMethod == 'card' and order.cardType %}
			<span style="font-size:11px; color:var(--muted); text-transform:uppercase;">{{ order.cardType }}</span>
		{% endif %}
	</td>
	<td class="oi-status-cell">
		{% if order.status == 'pending' %}
			<span class="oi-badge pending">
				<i class="fas fa-clock"></i>
				Pending</span>
		{% elseif order.status == 'completed' %}
			<span class="oi-badge completed">
				<i class="fas fa-check-circle"></i>
				Completed</span>
		{% else %}
			<span class="oi-badge cancelled">
				<i class="fas fa-times-circle"></i>
				Cancelled</span>
		{% endif %}
	</td>
	<td>
		<span style="color:var(--muted); font-size:12px;">
			<i class="far fa-calendar" style="margin-right:4px;"></i>
			{{ order.createdAt|date('M d, Y') }}<br>
			<small>{{ order.createdAt|date('h:i A') }}</small>
		</span>
	</td>
	<td>
		<div class="oi-actions">
			<a href="{{ path('app_order_show', {'id': order.id}) }}" class="oi-btn view">
				<i class="fas fa-eye"></i>
				View
			</a>
			{% if order.status == 'pending' %}
				<a href="{{ path('app_order_edit', {'id': order.id}) }}" class="oi-btn edit">
					<i class="fas fa-pen"></i>
					Edit
				</a>
				<form method="post" action="{{ path('app_order_cancel', {'id': order.id}) }}" class="oi-btn-form" onsubmit="return confirm('Cancel this pending order?');">
					<input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ order.id) }}">
					<button class="oi-btn delete">
						<i class="fas fa-ban"></i>
						Cancel
					</button>
				</form>
				<form method="post" action="{{ path('app_order_delete', {'id': order.id}) }}" class="oi-btn-form" onsubmit="return confirm('Are you sure you want to delete this order?');">
					<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
					<button class="oi-btn delete">
						<i class="fas fa-trash"></i>
						Delete
					</button>
				</form>
			{% endif %}
		</div>
	</td>
</tr>
