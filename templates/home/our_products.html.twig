{% extends 'base.html.twig' %}

{% block title %}Product - Bincafe{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown:       #2563eb;
        --brown-dark:  #1d4ed8;
        --brown-acc:   #3b82f6;
        --brown-light: #93c5fd;
        --cream:       #eff6ff;
        --cream2:      #dbeafe;
        --white:       #ffffff;
        --text:        #1e293b;
        --muted:       #64748b;
        --star:        #60a5fa;
    }

    body { background: var(--cream); font-family: 'DM Sans', sans-serif; color: var(--text); }

    /* ── PAGE HERO ── */
    .pg-hero {
    background: var(--white);
    padding: 60px 0 50px;
    margin-top: -1px;
    text-align: center;
}
    .pg-hero {
    background: var(--white);
    padding: 60px 0;
    margin-top: -1px;
    text-align: left;
    border-bottom: 1.5px solid var(--cream2);
}
.pg-hero span {
    font-size: 12px; letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--brown-light); font-weight: 700;
    display: block; margin-bottom: 10px;
}
.pg-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(38px, 5vw, 64px);
    color: var(--text); margin: 10px 0 18px;
    line-height: 1.1;
}
.pg-hero h1 span {
    color: var(--text) !important;
    font-style: italic;
    display: inline !important;
    font-size: inherit !important;
    letter-spacing: normal !important;
    text-transform: none !important;
    font-weight: inherit !important;
    margin: 0 !important;
}
    /* ── FILTER TABS ── */
    .pg-tabs {
        display: flex; gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
        padding: 40px 0 10px;
    }
    .pg-tab {
        padding: 9px 24px;
        border-radius: 30px;
        font-size: 14px; font-weight: 600;
        border: 1.5px solid var(--cream2);
        background: var(--white);
        color: var(--muted);
        cursor: pointer;
        transition: all .2s;
    }
    .pg-tab.active, .pg-tab:hover {
        background: var(--brown-dark);
        color: #fff;
        border-color: var(--brown-dark);
    }

    /* ── PRODUCT CARDS ── */
    .pg-section { padding: 50px 0 90px; }
    .pg-card {
        background: var(--white);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0,0,0,.06);
        transition: transform .3s, box-shadow .3s;
        height: 100%;
    }
    .pg-card:hover { transform: translateY(-6px); box-shadow: 0 14px 40px rgba(0,0,0,.11); }
    .pg-card-img { position: relative; overflow: hidden; height: 210px; }
    .pg-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
    .pg-card:hover .pg-card-img img { transform: scale(1.05); }
    .pg-badge {
        position: absolute; top: 14px; left: 14px;
        background: var(--brown-dark);
        color: #fff;
        font-size: 11px; font-weight: 700;
        letter-spacing: 1px; text-transform: uppercase;
        padding: 4px 12px; border-radius: 20px;
    }
    .pg-card-body { padding: 20px 22px 24px; }
    .pg-stars { color: var(--star); font-size: 13px; margin-bottom: 6px; }
    .pg-stars span { color: var(--muted); font-size: 12px; margin-left: 4px; }
    .pg-card-body h4 {
        font-family: 'Playfair Display', serif;
        font-size: 20px; color: var(--text);
        margin-bottom: 6px;
    }
    .pg-card-body p { font-size: 13px; color: var(--muted); line-height: 1.65; margin-bottom: 8px; }

    /* nutrition pill */
    .pg-nutrition {
        display: flex; flex-wrap: wrap; gap: 6px;
        margin-bottom: 16px;
    }
    .pg-nut-pill {
        background: var(--cream2);
        color: var(--brown);
        font-size: 11px; font-weight: 700;
        padding: 3px 10px; border-radius: 20px;
    }

    .pg-card-footer {
        display: flex; align-items: center;
        justify-content: space-between;
        border-top: 1.5px solid var(--cream2);
        padding-top: 14px;
    }
    .pg-price {
        font-family: 'Playfair Display', serif;
        font-size: 22px; font-weight: 700;
        color: var(--brown-dark);
    }
    .pg-add {
        width: 36px; height: 36px;
        background: var(--brown-dark);
        color: #fff; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; text-decoration: none;
        transition: background .2s; line-height: 1;
    }
    .pg-add:hover { background: var(--brown-acc); color: #fff; }

    /* ── CTA STRIP ── */
    .pg-cta {
        background: var(--brown-dark);
        padding: 70px 0;
        text-align: center;
    }
    .pg-cta h2 {
        font-family: 'Playfair Display', serif;
        font-size: 36px; color: #fff; margin-bottom: 10px;
    }
    .pg-cta p { color: rgba(255,255,255,.65); font-size: 14px; margin-bottom: 28px; }
    .pg-cta a {
        display: inline-block;
        background: var(--brown-light);
        color: #fff; padding: 13px 34px;
        border-radius: 40px; font-weight: 700;
        font-size: 14px; text-decoration: none;
        transition: background .2s;
    }
    .pg-cta a:hover { background: var(--brown-acc); color: #fff; }
</style>
{% endblock %}

