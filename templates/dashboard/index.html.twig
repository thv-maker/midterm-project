{% extends 'base.html.twig' %}

{% block title %}Dashboard
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
	<script>
		(() => {
const statsUrl = {{ path('app_dashboard_stats')|json_encode|raw }};
const lowStockPanelUrl = {{ path('app_dashboard_stock_low_stock_panel')|json_encode|raw }};
const initialSalesData = {{ salesData|json_encode|raw }};
let salesChart = null;
let refreshTimer = null;
const revenueLiveBadge = document.getElementById('db-revenue-live-badge');

function formatPeso(amount) {
return '₱' + Number(amount || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function setRevenueLiveBadge(state) {
if (!revenueLiveBadge) return;
const styles = {
live: { color: '#a8e6cf', text: '● Live' },
connecting: { color: '#fde68a', text: '○ Updating…' },
polling: { color: '#c4b5fd', text: '○ Polling' },
};
const s = styles[state] || styles.connecting;
revenueLiveBadge.style.color = s.color;
revenueLiveBadge.textContent = s.text;
}

function initSalesChart(rawData) {
const ctx = document.getElementById('salesChart');
if (!ctx || typeof Chart === 'undefined') return;
const data = Array.isArray(rawData) ? rawData : [];
const labels = data.map((item, i) => item.day || 'Day ' + (i + 1));
const values = data.map(item => parseFloat(item.total) || 0);
if (salesChart) {
salesChart.data.labels = labels;
salesChart.data.datasets[0].data = values;
salesChart.update('none');
return;
}
salesChart = new Chart(ctx, {
type: 'line',
data: {
labels,
datasets: [{
label: 'Daily Sales (₱)',
data: values,
borderColor: '#8B5E3C',
backgroundColor: 'rgba(139,94,60,.08)',
tension: 0.4,
fill: true,
borderWidth: 3,
pointBackgroundColor: '#3e1f0d',
pointBorderColor: '#fff',
pointBorderWidth: 2,
pointRadius: 5,
pointHoverRadius: 7,
}],
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: {
legend: { display: true, position: 'top' },
tooltip: {
callbacks: {
label: ctx => formatPeso(ctx.parsed.y),
},
},
},
scales: {
y: {
beginAtZero: true,
ticks: { callback: v => '₱' + Number(v).toLocaleString() },
},
x: { grid: { display: false } },
},
},
});
window.salesChart = salesChart;
}

const refreshLowStockPanel = async () => {
const panel = document.getElementById('db-low-stock-panel');
if (!panel) return;
try {
const response = await fetch(lowStockPanelUrl, {
headers: { 'X-Requested-With': 'XMLHttpRequest' },
credentials: 'same-origin',
});
if (!response.ok) return;
const html = await response.text();
panel.outerHTML = '<div id="db-low-stock-panel">' + html.trim() + '</div>';
} catch (e) {
console.warn('Low stock panel refresh failed', e);
}
};

const refreshStats = async () => {
try {
const response = await fetch(statsUrl, {
headers: { 'X-Requested-With': 'XMLHttpRequest' },
credentials: 'same-origin',
});
if (!response.ok) {
setRevenueLiveBadge('polling');
return;
}
const data = await response.json();
const productsEl = document.getElementById('db-stat-products');
const stocksEl = document.getElementById('db-stat-stocks');
const revenueEl = document.getElementById('db-stat-revenue');
const changeEl = document.getElementById('db-stat-revenue-change');
const todayRevenueEl = document.getElementById('db-stat-today-revenue');
if (productsEl) productsEl.textContent = data.totalProducts;
if (stocksEl) stocksEl.textContent = data.totalStocks;
if (revenueEl) revenueEl.textContent = formatPeso(data.totalRevenue);
if (todayRevenueEl) todayRevenueEl.textContent = 'Today: ' + formatPeso(data.todayRevenue);
if (changeEl) {
const change = Number(data.revenueChange);
changeEl.textContent = (change >= 0 ? '+' : '') + change.toFixed(1) + '% from yesterday';
changeEl.className = 'db-stat-badge ' + (change >= 0 ? 'positive' : 'negative');
}
if (Array.isArray(data.salesData)) {
initSalesChart(data.salesData);
}
await refreshLowStockPanel();
setRevenueLiveBadge('live');
} catch (e) {
console.warn('Dashboard stats refresh failed', e);
setRevenueLiveBadge('polling');
}
};

const scheduleRefresh = () => {
if (refreshTimer) return;
refreshTimer = setTimeout(async () => {
refreshTimer = null;
setRevenueLiveBadge('connecting');
await refreshStats();
}, 800);
};

try {
CafeRealtime.connect(['/orders', '/products', '/users', '/activity-logs', '/stocks'], (topic) => {
if (topic === '/orders') scheduleRefresh();
else scheduleRefresh();
}, (status) => {
if (status === 'subscribed' || status === 'connected') setRevenueLiveBadge('live');
else if (status === 'connecting') setRevenueLiveBadge('connecting');
else setRevenueLiveBadge('polling');
});
} catch (e) {
console.warn('WebSocket unavailable for dashboard', e);
setRevenueLiveBadge('polling');
}

initSalesChart(initialSalesData);
setInterval(refreshStats, 5000);
setTimeout(refreshStats, 1000);
})();
	</script>
{% endblock %}

{% block stylesheets %}
	<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
	<style>:root
	{
		--brown-dark: #3e1f0d;
		--brown-mid: #6d4c41;
		--brown-acc: #8B5E3C;
		--brown-light: #c49a6c;
		--cream: #faf7f4;
		--cream2: #f3ece4;
		--white: #ffffff;
		--text: #2b1a0f;
		--muted: #9e8070;
	}

	body {
		font-family: 'DM Sans', sans-serif;
		background: var(--cream);
		color: var(--text);
	}

	.db-wrap {
		padding: 32px 36px;
	}

	/* ── HEADER ── */
	.db-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: var(--brown-dark);
		border-radius: 18px;
		padding: 28px 32px;
		margin-bottom: 28px;
		position: relative;
		overflow: hidden;
	}
	.db-header::before {
		content: '';
		position: absolute;
		top: -60px;
		right: -60px;
		width: 200px;
		height: 200px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.04);
	}
	.db-header-text h1 {
		font-family: 'Playfair Display', serif;
		font-size: 26px;
		color: #fff;
		margin: 0 0 4px;
		font-weight: 700;
	}
	.db-header-text p {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.55);
		margin: 0;
	}
	.db-user {
		display: flex;
		align-items: center;
		gap: 14px;
		position: relative;
		z-index: 1;
	}
	.db-user-info {
		text-align: right;
	}
	.db-user-role {
		font-size: 11px;
		color: var(--brown-light);
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
	}
	.db-user-email {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.8);
		font-weight: 500;
	}
	.db-avatar {
		width: 46px;
		height: 46px;
		background: rgba(255, 255, 255, 0.12);
		border: 2px solid rgba(255, 255, 255, 0.2);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
	}

	/* ── STAT CARDS ── */
	.db-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
		margin-bottom: 24px;
	}
	.db-stat {
		background: var(--white);
		border-radius: 16px;
		padding: 24px;
		display: flex;
		align-items: center;
		gap: 18px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
		transition: transform 0.3s, box-shadow 0.3s;
		border-left: 4px solid var(--brown-acc);
	}
	.db-stat:hover {
		transform: translateY(-4px);
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.09);
	}
	.db-stat-icon {
		width: 54px;
		height: 54px;
		border-radius: 14px;
		background: var(--cream2);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.db-stat-icon svg {
		width: 24px;
		height: 24px;
		stroke: var(--brown-mid);
	}
	.db-stat-label {
		font-size: 12px;
		color: var(--muted);
		margin-bottom: 6px;
		font-weight: 600;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}
	.db-stat-value {
		font-family: 'Playfair Display', serif;
		font-size: 30px;
		font-weight: 700;
		color: var(--text);
		line-height: 1;
		margin-bottom: 6px;
	}
	.db-stat-badge {
		font-size: 12px;
		font-weight: 600;
		color: var(--brown-acc);
	}
	.db-stat-badge.positive {
		color: #2e7d32;
	}
	.db-stat-badge.negative {
		color: #c62828;
	}

	/* ── GRID ── */
	.db-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 20px;
		margin-bottom: 24px;
	}

	/* ── CARDS ── */
	.db-card {
		background: var(--white);
		border-radius: 16px;
		padding: 26px;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
	}
	.db-card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 22px;
		padding-bottom: 16px;
		border-bottom: 1.5px solid var(--cream2);
	}
	.db-card-header h3 {
		font-family: 'Playfair Display', serif;
		font-size: 17px;
		color: var(--text);
		margin: 0;
		font-weight: 700;
	}
	.db-card-header a {
		font-size: 13px;
		color: var(--brown-acc);
		text-decoration: none;
		font-weight: 600;
	}
	.db-card-header a:hover {
		color: var(--brown-dark);
	}

	/* ── PRODUCT ITEMS ── */
	.db-product-item {
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 12px 0;
		border-bottom: 1.5px solid var(--cream2);
		text-decoration: none;
		transition: all 0.2s;
	}
	.db-product-item:last-child {
		border-bottom: none;
	}
	.db-product-item:hover {
		padding-left: 6px;
	}
	.db-product-icon {
		width: 42px;
		height: 42px;
		background: var(--cream2);
		border-radius: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.db-product-icon svg {
		width: 20px;
		height: 20px;
		stroke: var(--brown-mid);
	}
	.db-product-name {
		font-size: 14px;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 2px;
	}
	.db-product-price {
		font-size: 12px;
		color: var(--muted);
	}
	.db-empty {
		text-align: center;
		padding: 30px 0;
		color: var(--muted);
		font-size: 14px;
	}

	/* ── STOCK TABLE ── */
	.db-table {
		width: 100%;
		border-collapse: collapse;
	}
	.db-table th {
		padding: 10px 14px;
		text-align: left;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: var(--muted);
		border-bottom: 2px solid var(--cream2);
	}
	.db-table th:not(:first-child) {
		text-align: center;
	}
	.db-table td {
		padding: 14px;
		font-size: 13px;
		color: var(--text);
		border-bottom: 1.5px solid var(--cream2);
	}
	.db-table td:not(:first-child) {
		text-align: center;
	}
	.db-table tr:last-child td {
		border-bottom: none;
	}
	.db-table tr:hover td {
		background: var(--cream);
	}
	.db-badge {
		display: inline-block;
		padding: 4px 12px;
		border-radius: 20px;
		font-size: 11px;
		font-weight: 700;
	}
	.db-badge.out {
		background: #ffebee;
		color: #c62828;
	}
	.db-badge.low {
		background: #fff3e0;
		color: #f57c00;
	}

	/* ── GOOD STOCK ── */
	.db-good-stock {
		text-align: center;
		padding: 40px 20px;
	}
	.db-good-stock svg {
		stroke: #2e7d32;
		margin-bottom: 14px;
	}
	.db-good-stock p {
		color: #2e7d32;
		font-weight: 600;
		font-size: 15px;
		margin-bottom: 4px;
	}
	.db-good-stock small {
		color: var(--muted);
		font-size: 13px;
	}

	@media(max-width: 1024px) {
		.db-grid {
			grid-template-columns: 1fr;
		}
		.db-stats {
			grid-template-columns: 1fr;
		}
	}
</style>{% endblock %}{% block body %}
<div
	class="db-wrap">

	{# ── HEADER ── #}
	<div class="db-header">
		<div class="db-header-text">
			<h1>Welcome back, Carpe Diem ☕</h1>
			<p>Here's what's happening in your café today.</p>
		</div>
		<div class="db-user">
			<div class="db-user-info">
				<div class="db-user-role">
					{% if is_granted('ROLE_ADMIN') %}Administrator
						{% elseif is_granted('ROLE_STAFF') %}Staff
						{% elseif is_granted('ROLE_USER') %}User
						{% else %}Guest
					{% endif %}
				</div>
				<div class="db-user-email">{{ app.user.email }}</div>
			</div>
			<div class="db-avatar">
				<svg fill="currentColor" viewbox="0 0 24 24" style="width:22px;height:22px;">
					<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
				</svg>
			</div>
		</div>
	</div>

	{# ── STATS ── #}
	<div class="db-stats">
		<div class="db-stat">
			<div class="db-stat-icon">
				<svg fill="none" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
			</div>
			<div>
				<div class="db-stat-label">Total Products</div>
				<div class="db-stat-value" id="db-stat-products">{{ totalProducts }}</div>
				<div class="db-stat-badge">Products in system</div>
			</div>
		</div>
		<div class="db-stat">
			<div class="db-stat-icon">
				<svg fill="none" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
			</div>
			<div>
				<div class="db-stat-label">Stock Items</div>
				<div class="db-stat-value" id="db-stat-stocks">{{ totalStocks }}</div>
				<div class="db-stat-badge">Items in inventory</div>
			</div>
		</div>
		<div class="db-stat">
			<div class="db-stat-icon">
				<svg fill="none" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
			</div>
			<div>
				<div class="db-stat-label">Total Revenue
					<span id="db-revenue-live-badge" style="font-size:11px;font-weight:600;color:#a8e6cf;margin-left:6px;">● Live</span>
				</div>
				<div class="db-stat-value" id="db-stat-revenue">₱{{ totalRevenue|number_format(2) }}</div>
				<div class="db-stat-badge {% if revenueChange >= 0 %}positive{% else %}negative{% endif %}" id="db-stat-revenue-change">
					{% if revenueChange >= 0 %}+{% endif %}{{ revenueChange|number_format(1) }}% from yesterday
				</div>
				<div class="db-stat-badge" id="db-stat-today-revenue" style="margin-top:4px;">Today: ₱{{ todayRevenue|number_format(2) }}</div>
			</div>
		</div>
	</div>

	{# ── CHART + PRODUCTS ── #}
	<div class="db-grid">
		<div class="db-card">
			<div class="db-card-header">
				<h3>Sales Analytics (Last 7 Days)</h3>
				<span style="font-size:12px;color:var(--muted);">Completed orders only</span>
			</div>
			<div style="position:relative; height:250px;">
				<canvas id="salesChart"></canvas>
			</div>
		</div>

		<div class="db-card">
			<div class="db-card-header">
				<h3>Recent Products</h3>
				{% if is_granted('ROLE_ADMIN') %}
					<a href="{{ path('app_dashboard_products') }}">See all</a>
				{% endif %}
			</div>
			{% if recentProducts is empty %}
				<div class="db-empty">No products added yet</div>
			{% else %}
				{% for product in recentProducts %}
					<a href="{{ path('app_dashboard_product_show', {'id': product.id}) }}" class="db-product-item">
						<div class="db-product-icon">
							<svg fill="none" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
						</div>
						<div>
							<div class="db-product-name">{{ product.name }}</div>
							<div class="db-product-price">₱{{ product.price }}</div>
						</div>
					</a>
				{% endfor %}
			{% endif %}
		</div>
	</div>

	{# ── LOW STOCK ── #}
	<div class="db-card">
		<div class="db-card-header">
			<h3>Low Stock Alert</h3>
			{% if is_granted('ROLE_STAFF') %}
				<a href="{{ path('app_dashboard_stocks') }}">See all</a>
			{% endif %}
		</div>
		<div id="db-low-stock-panel">
			{% include 'dashboard/_low_stock_panel.html.twig' %}
		</div>
	</div>

	<div class="db-card" style="margin-top: 20px;">
		<div class="db-card-header">
			<h3>Most Ordered Products</h3>
			<span style="font-size: 12px; color: var(--muted);">Qty ordered by customers</span>
		</div>
		{% if topOrderedProducts is empty %}
			<div class="db-empty">No order item data yet.</div>
		{% else %}
			<div style="overflow-x:auto;">
				<table class="db-table">
					<thead>
						<tr>
							<th>Product</th>
							<th>Total Qty Ordered</th>
							<th>Customers Ordered</th>
						</tr>
					</thead>
					<tbody>
						{% for row in topOrderedProducts %}
							<tr>
								<td>
									<strong>{{ row.product_name }}</strong>
								</td>
								<td>{{ row.total_quantity }}</td>
								<td>{{ row.customer_count }}</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% endif %}
	</div>

</div>

{% endblock %}
