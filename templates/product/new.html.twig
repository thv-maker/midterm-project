{% extends 'base.html.twig' %}

{% block title %}New Product{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #1d4ed8;
        --brown-mid:   #2563eb;
        --brown-acc:   #3b82f6;
        --brown-light: #93c5fd;
        --cream:       #eff6ff;
        --cream2:      #dbeafe;
        --white:       #ffffff;
        --text:        #1e293b;
        --muted:       #64748b;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .pn-wrap { padding: 32px 36px; }

    /* ── HEADER ── */
    .pn-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .pn-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .pn-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .pn-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .pn-back {
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15);
        color: #fff;
        padding: 10px 22px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .pn-back:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* ── CARDS ── */
    .pn-card {
        background: var(--white);
        border-radius: 16px;
        padding: 28px 32px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        margin-bottom: 20px;
    }
    .pn-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 22px;
        padding-bottom: 14px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .pn-card-title i { color: var(--brown-acc); }

    /* ── FIELDS ── */
    .pn-label {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 8px;
    }
    .pn-label i { color: var(--brown-light); font-size: 13px; }

    .pn-card input[type="text"],
    .pn-card input[type="number"],
    .pn-card select,
    .pn-card textarea {
        width: 100%;
        padding: 13px 16px;
        border: 1.5px solid var(--cream2);
        border-radius: 10px;
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        background: var(--cream);
        outline: none;
        transition: border-color .2s, background .2s;
        margin-bottom: 6px;
        appearance: none;
    }
    .pn-card input:focus,
    .pn-card select:focus,
    .pn-card textarea:focus {
        border-color: var(--brown-acc);
        background: var(--white);
    }
    .pn-card input::placeholder,
    .pn-card textarea::placeholder { color: var(--muted); }

    .pn-help {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 20px;
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .pn-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    /* nutrition highlight */
    .pn-nut-card {
        background: var(--white);
        border-radius: 16px;
        padding: 28px 32px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        margin-bottom: 20px;
        border-left: 4px solid var(--brown-light);
    }

    /* ── ACTIONS ── */
    .pn-actions {
        display: flex;
        gap: 12px;
        padding-top: 20px;
        border-top: 1.5px solid var(--cream2);
        margin-top: 8px;
    }
    .pn-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 40px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: background .2s, transform .2s;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }
    .pn-btn.primary { background: var(--brown-dark); color: #fff; }
    .pn-btn.primary:hover { background: var(--brown-acc); color: #fff; transform: translateY(-2px); }
    .pn-btn.cancel {
        background: transparent;
        color: var(--muted);
        border: 2px solid var(--cream2);
        text-decoration: none;
    }
    .pn-btn.cancel:hover { border-color: var(--brown-light); color: var(--text); transform: translateY(-2px); }

    @media (max-width: 768px) {
        .pn-row { grid-template-columns: 1fr; }
        .pn-wrap { padding: 20px; }
    }
</style>
{% endblock %}

{% block body %}
<div class="pn-wrap">

    {# ── HEADER ── #}
    <div class="pn-header">
        <div>
            <h1><i class="fas fa-plus-circle"></i> Create New Product</h1>
            <p>Add a new item to your café menu with full nutrition facts.</p>
        </div>
        <a href="{{ path('app_dashboard_products') }}" class="pn-back">
            <i class="fas fa-arrow-left"></i> Back to Products
        </a>
    </div>

    {{ form_start(form) }}

        {# ── BASIC INFO ── #}
        <div class="pn-card">
            <div class="pn-card-title">
                <i class="fas fa-info-circle"></i> Basic Information
            </div>

            <label class="pn-label" for="{{ form.name.vars.id }}">
                <i class="fas fa-tag"></i> Product Name
            </label>
            {{ form_widget(form.name, {'attr': {'placeholder': 'e.g. Caramel Macchiato'}}) }}
            {{ form_errors(form.name) }}
            <div class="pn-help"><i class="fas fa-info-circle"></i> Enter the full name of the product.</div>

            <div class="pn-row">
                <div>
                    <label class="pn-label" for="{{ form.category.vars.id }}">
                        <i class="fas fa-list"></i> Category
                    </label>
                    {{ form_widget(form.category) }}
                    {{ form_errors(form.category) }}
                    <div class="pn-help"><i class="fas fa-info-circle"></i> Select a product category.</div>
                </div>
                <div>
                    <label class="pn-label" for="{{ form.price.vars.id }}">
                        <i class="fas fa-peso-sign"></i> Price (₱)
                    </label>
                    {{ form_widget(form.price, {'attr': {'placeholder': '0.00', 'step': '0.01'}}) }}
                    {{ form_errors(form.price) }}
                    <div class="pn-help"><i class="fas fa-info-circle"></i> Set the selling price in PHP.</div>
                </div>
            </div>
        </div>

        {# ── NUTRITION INFO ── #}
        <div class="pn-nut-card pn-card">
            <div class="pn-card-title">
                <i class="fas fa-clipboard-list"></i> Nutritional Information
            </div>

            <div class="pn-row">
                <div>
                    <label class="pn-label" for="{{ form.calories.vars.id }}">
                        <i class="fas fa-fire"></i> Calories (kcal)
                    </label>
                    {{ form_widget(form.calories, {'attr': {'placeholder': 'e.g. 250'}}) }}
                    {{ form_errors(form.calories) }}
                    <div class="pn-help"><i class="fas fa-info-circle"></i> Total calorie content per serving.</div>
                </div>
                <div>
                    <label class="pn-label" for="{{ form.sugarGrams.vars.id }}">
                        <i class="fas fa-cubes"></i> Sugar (g)
                    </label>
                    {{ form_widget(form.sugarGrams, {'attr': {'placeholder': 'e.g. 25.5', 'step': '0.1'}}) }}
                    {{ form_errors(form.sugarGrams) }}
                    <div class="pn-help"><i class="fas fa-info-circle"></i> Sugar content in grams per serving.</div>
                </div>
            </div>

            <label class="pn-label" for="{{ form.caffeineMg.vars.id }}">
                <i class="fas fa-bolt"></i> Caffeine (mg)
            </label>
            {{ form_widget(form.caffeineMg, {'attr': {'placeholder': 'e.g. 75'}}) }}
            {{ form_errors(form.caffeineMg) }}
            <div class="pn-help"><i class="fas fa-info-circle"></i> Caffeine content in milligrams per serving.</div>

            <div class="pn-actions">
                <button type="submit" class="pn-btn primary">
                    <i class="fas fa-check"></i> Create Product
                </button>
                <a href="{{ path('app_dashboard_products') }}" class="pn-btn cancel">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </div>

    {{ form_end(form) }}

</div>
{% endblock %}
