{% extends 'base.html.twig' %}

{% block title %}Products - Bincafe{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #c2410c;
        --brown-mid:   #ea580c;
        --brown-acc:   #f97316;
        --brown-light: #fdba74;
        --cream:       #fff7ed;
        --cream2:      #ffedd5;
        --white:       #ffffff;
        --text:        #431407;
        --muted:       #b45309;
        --star:        #e8a020;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .pd-wrap { padding: 32px 36px; }

    .pd-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .pd-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .pd-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .pd-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .pd-add-btn {
        background: rgba(255,255,255,.12);
        border: 1.5px solid rgba(255,255,255,.2);
        color: #fff;
        padding: 11px 24px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .pd-add-btn:hover { background: rgba(255,255,255,.2); color: #fff; }

    .pd-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 22px;
    }

    .pd-card {
        background: var(--white);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        transition: transform .3s, box-shadow .3s;
        border-top: 4px solid var(--brown-acc);
    }
    .pd-card:hover { transform: translateY(-6px); box-shadow: 0 14px 36px rgba(0,0,0,.11); }

    .pd-card-body { padding: 22px 24px 0; }

    .pd-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
    }
    .pd-card-name {
        font-family: 'Playfair Display', serif;
        font-size: 19px;
        font-weight: 700;
        color: var(--text);
        margin: 0;
        flex: 1;
        padding-right: 10px;
    }
    .pd-cat-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: var(--cream2);
        color: var(--brown-dark);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 20px;
        white-space: nowrap;
    }

    .pd-price {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        font-weight: 700;
        color: var(--brown-dark);
        margin-bottom: 18px;
    }

    .pd-nutrition {
        background: var(--cream);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 14px;
    }
    .pd-nut-title {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .pd-nut-title i { color: var(--brown-light); }
    .pd-nut-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 7px 0;
        border-bottom: 1.5px solid var(--cream2);
    }
    .pd-nut-row:last-child { border-bottom: none; }
    .pd-nut-label {
        font-size: 12px;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .pd-nut-label i { font-size: 11px; color: var(--brown-light); width: 14px; }
    .pd-nut-value {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
    }

    /* ── STOCK INDICATOR ── */
    .pd-stock {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px;
        border-radius: 10px;
        margin-bottom: 16px;
        font-size: 12px;
        font-weight: 700;
    }
    .pd-stock.healthy { background: #e8f5e9; color: #2e7d32; }
    .pd-stock.low     { background: #fff3e0; color: #e65100; }
    .pd-stock.out     { background: #ffebee; color: #c62828; }
    .pd-stock-left { display: flex; align-items: center; gap: 6px; }

    .pd-card-footer {
        display: flex;
        border-top: 1.5px solid var(--cream2);
    }
    .pd-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 14px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background .2s;
    }
    .pd-btn.view {
        background: var(--cream);
        color: var(--brown-dark);
        border-right: 1.5px solid var(--cream2);
    }
    .pd-btn.view:hover { background: var(--cream2); }
    .pd-btn.edit {
        background: var(--brown-dark);
        color: #fff;
    }
    .pd-btn.edit:hover { background: var(--brown-acc); }

    .pd-empty {
        background: var(--white);
        border-radius: 16px;
        padding: 70px 30px;
        text-align: center;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }
    .pd-empty i { font-size: 52px; color: var(--cream2); margin-bottom: 18px; display: block; }
    .pd-empty p { font-size: 15px; color: var(--muted); margin-bottom: 24px; }

    @media (max-width: 768px) {
        .pd-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<div class="pd-wrap">

    {# ── HEADER ── #}
    <div class="pd-header">
        <div>
            <h1><i class="fas fa-coffee"></i> Products</h1>
            <p>Manage your café menu with full nutrition facts on every item.</p>
        </div>
        <a href="{{ path('app_dashboard_product_new') }}" class="pd-add-btn">
            <i class="fas fa-plus"></i> Add New Product
        </a>
    </div>

    {# ── GRID ── #}
    {% if products is empty %}
        <div class="pd-empty">
            <i class="fas fa-coffee"></i>
            <p>No products found. Start by adding your first product!</p>
            <a href="{{ path('app_dashboard_product_new') }}" style="display:inline-flex; align-items:center; gap:8px; background:var(--brown-dark); color:#fff; padding:12px 28px; border-radius:40px; text-decoration:none; font-weight:700; font-size:14px;">
                <i class="fas fa-plus"></i> Add First Product
            </a>
        </div>
    {% else %}
        <div class="pd-grid" id="pd-grid">
            {% for product in products %}
            {% include 'product/_card.html.twig' %}
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const cardUrlTemplate = {{ path(productCardRoute|default('app_dashboard_product_card'), { id: 0 })|json_encode|raw }}.replace('/0', '/');
            const grid = document.getElementById('pd-grid');
            const knownIds = new Set(
                [...document.querySelectorAll('[data-product-id]')].map(el => parseInt(el.dataset.productId, 10))
            );

            async function fetchCard(productId) {
                const response = await fetch(cardUrlTemplate + productId, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                });
                if (!response.ok) throw new Error('Failed to load product card');
                return response.text();
            }

            async function insertCard(productId) {
                if (!grid || knownIds.has(productId)) return;
                const html = await fetchCard(productId);
                const template = document.createElement('template');
                template.innerHTML = html.trim();
                const card = template.content.querySelector('[data-product-id]');
                if (!card) return;
                card.classList.add('pd-card-new');
                grid.insertBefore(card, grid.firstChild);
                knownIds.add(productId);
            }

            async function refreshCard(productId) {
                if (!grid) return;
                const existing = grid.querySelector('[data-product-id="' + productId + '"]');
                if (!existing) return insertCard(productId);
                const html = await fetchCard(productId);
                const template = document.createElement('template');
                template.innerHTML = html.trim();
                const card = template.content.querySelector('[data-product-id]');
                if (card) existing.replaceWith(card);
            }

            async function handleEvent(payload) {
                if (!payload?.productId) return;
                if (payload.type === 'deleted') {
                    const el = grid?.querySelector('[data-product-id="' + payload.productId + '"]');
                    if (el) {
                        el.remove();
                        knownIds.delete(payload.productId);
                    }
                    return;
                }
                if (payload.type === 'created') {
                    await insertCard(payload.productId);
                    return;
                }
                if (payload.type === 'updated') {
                    await refreshCard(payload.productId);
                }
            }

            try {
                CafeRealtime.connect('/products', (_topic, payload) => handleEvent(payload));
            } catch (e) {
                console.warn('WebSocket unavailable for products', e);
            }
        })();
    </script>
{% endblock %}