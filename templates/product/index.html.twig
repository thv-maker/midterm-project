{% extends 'base.html.twig' %}

{% block title %}Products - Carpe Diem{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #3e1f0d;
        --brown-mid:   #6d4c41;
        --brown-acc:   #8B5E3C;
        --brown-light: #c49a6c;
        --cream:       #faf7f4;
        --cream2:      #f3ece4;
        --white:       #ffffff;
        --text:        #2b1a0f;
        --muted:       #9e8070;
        --star:        #e8a020;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .pd-wrap { padding: 32px 36px; }

    /* ── HEADER ── */
    .pd-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .pd-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .pd-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .pd-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .pd-add-btn {
        background: rgba(255,255,255,.12);
        border: 1.5px solid rgba(255,255,255,.2);
        color: #fff;
        padding: 11px 24px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .pd-add-btn:hover { background: rgba(255,255,255,.2); color: #fff; }

    /* ── GRID ── */
    .pd-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 22px;
    }

    /* ── PRODUCT CARD ── */
    .pd-card {
        background: var(--white);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        transition: transform .3s, box-shadow .3s;
        border-top: 4px solid var(--brown-acc);
    }
    .pd-card:hover { transform: translateY(-6px); box-shadow: 0 14px 36px rgba(0,0,0,.11); }

    .pd-card-body { padding: 22px 24px 0; }

    .pd-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
    }
    .pd-card-name {
        font-family: 'Playfair Display', serif;
        font-size: 19px;
        font-weight: 700;
        color: var(--text);
        margin: 0;
        flex: 1;
        padding-right: 10px;
    }
    .pd-cat-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: var(--cream2);
        color: var(--brown-dark);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 20px;
        white-space: nowrap;
    }

    .pd-price {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        font-weight: 700;
        color: var(--brown-dark);
        margin-bottom: 18px;
    }

    /* nutrition box */
    .pd-nutrition {
        background: var(--cream);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 20px;
    }
    .pd-nut-title {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .pd-nut-title i { color: var(--brown-light); }
    .pd-nut-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 7px 0;
        border-bottom: 1.5px solid var(--cream2);
    }
    .pd-nut-row:last-child { border-bottom: none; }
    .pd-nut-label {
        font-size: 12px;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .pd-nut-label i { font-size: 11px; color: var(--brown-light); width: 14px; }
    .pd-nut-value {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
    }

    /* actions */
    .pd-card-footer {
        display: flex;
        border-top: 1.5px solid var(--cream2);
    }
    .pd-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 14px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: background .2s;
    }
    .pd-btn.view {
        background: var(--cream);
        color: var(--brown-dark);
        border-right: 1.5px solid var(--cream2);
    }
    .pd-btn.view:hover { background: var(--cream2); }
    .pd-btn.edit {
        background: var(--brown-dark);
        color: #fff;
    }
    .pd-btn.edit:hover { background: var(--brown-acc); }

    /* empty */
    .pd-empty {
        background: var(--white);
        border-radius: 16px;
        padding: 70px 30px;
        text-align: center;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }
    .pd-empty i { font-size: 52px; color: var(--cream2); margin-bottom: 18px; display: block; }
    .pd-empty p { font-size: 15px; color: var(--muted); margin-bottom: 24px; }

    @media (max-width: 768px) {
        .pd-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<div class="pd-wrap">

    {# ── HEADER ── #}
    <div class="pd-header">
        <div>
            <h1><i class="fas fa-coffee"></i> Products</h1>
            <p>Manage your café menu with full nutrition facts on every item.</p>
        </div>
        <a href="{{ path('app_dashboard_product_new') }}" class="pd-add-btn">
            <i class="fas fa-plus"></i> Add New Product
        </a>
    </div>

    {# ── GRID ── #}
    {% if products is empty %}
        <div class="pd-empty">
            <i class="fas fa-coffee"></i>
            <p>No products found. Start by adding your first product!</p>
            <a href="{{ path('app_dashboard_product_new') }}" style="display:inline-flex; align-items:center; gap:8px; background:var(--brown-dark); color:#fff; padding:12px 28px; border-radius:40px; text-decoration:none; font-weight:700; font-size:14px;">
                <i class="fas fa-plus"></i> Add First Product
            </a>
        </div>
    {% else %}
        <div class="pd-grid">
            {% for product in products %}
            <div class="pd-card">
                <div class="pd-card-body">
                    <div class="pd-card-top">
                        <h3 class="pd-card-name">{{ product.name }}</h3>
                        <span class="pd-cat-badge"><i class="fas fa-tag"></i> {{ product.category }}</span>
                    </div>

                    <div class="pd-price">₱{{ product.price|number_format(2) }}</div>

                    <div class="pd-nutrition">
                        <div class="pd-nut-title">
                            <i class="fas fa-clipboard-list"></i> Nutritional Information
                        </div>
                        <div class="pd-nut-row">
                            <span class="pd-nut-label"><i class="fas fa-fire"></i> Calories</span>
                            <span class="pd-nut-value">{{ product.calories }} kcal</span>
                        </div>
                        <div class="pd-nut-row">
                            <span class="pd-nut-label"><i class="fas fa-cubes"></i> Sugar</span>
                            <span class="pd-nut-value">{{ product.sugarGrams }} g</span>
                        </div>
                        <div class="pd-nut-row">
                            <span class="pd-nut-label"><i class="fas fa-bolt"></i> Caffeine</span>
                            <span class="pd-nut-value">{{ product.caffeineMg }} mg</span>
                        </div>
                    </div>
                </div>

                <div class="pd-card-footer">
                    <a href="{{ path('app_dashboard_product_show', {'id': product.id}) }}" class="pd-btn view">
                        <i class="fas fa-eye"></i> View
                    </a>
                    <a href="{{ path('app_dashboard_product_edit', {'id': product.id}) }}" class="pd-btn edit">
                        <i class="fas fa-pen"></i> Edit
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
