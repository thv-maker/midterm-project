{% extends 'base.html.twig' %}

{% block title %}Edit Product - Carpe Diem{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #3e1f0d;
        --brown-mid:   #6d4c41;
        --brown-acc:   #8B5E3C;
        --brown-light: #c49a6c;
        --cream:       #faf7f4;
        --cream2:      #f3ece4;
        --white:       #ffffff;
        --text:        #2b1a0f;
        --muted:       #9e8070;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .pe-wrap { padding: 32px 36px; }

    /* ── HEADER ── */
    .pe-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .pe-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .pe-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .pe-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .pe-back {
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15);
        color: #fff;
        padding: 10px 22px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .pe-back:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* ── CARDS ── */
    .pe-card {
        background: var(--white);
        border-radius: 16px;
        padding: 28px 32px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        margin-bottom: 20px;
    }
    .pe-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 22px;
        padding-bottom: 14px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .pe-card-title i { color: var(--brown-acc); }

    /* nutrition card accent */
    .pe-nut-card { border-left: 4px solid var(--brown-light); }

    /* ── FIELDS ── */
    .pe-label {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 8px;
    }
    .pe-label i { color: var(--brown-light); font-size: 13px; }

    .pe-card input[type="text"],
    .pe-card input[type="number"],
    .pe-card select,
    .pe-card textarea {
        width: 100%;
        padding: 13px 16px;
        border: 1.5px solid var(--cream2);
        border-radius: 10px;
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        background: var(--cream);
        outline: none;
        transition: border-color .2s, background .2s;
        margin-bottom: 6px;
        appearance: none;
    }
    .pe-card input:focus,
    .pe-card select:focus { border-color: var(--brown-acc); background: var(--white); }
    .pe-card input::placeholder { color: var(--muted); }

    .pe-help {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 20px;
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .pe-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

    /* ── ACTIONS ── */
    .pe-actions {
        display: flex;
        gap: 12px;
        padding-top: 20px;
        border-top: 1.5px solid var(--cream2);
        margin-top: 8px;
    }
    .pe-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 40px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: background .2s, transform .2s;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }
    .pe-btn.primary { background: var(--brown-dark); color: #fff; }
    .pe-btn.primary:hover { background: var(--brown-acc); color: #fff; transform: translateY(-2px); }
    .pe-btn.cancel { background: transparent; color: var(--muted); border: 2px solid var(--cream2); }
    .pe-btn.cancel:hover { border-color: var(--brown-light); color: var(--text); transform: translateY(-2px); }

    /* ── DANGER ZONE ── */
    .pe-danger {
        background: var(--white);
        border-radius: 16px;
        padding: 24px 30px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        border-left: 4px solid #f44336;
    }
    .pe-danger-title {
        font-size: 15px;
        font-weight: 700;
        color: #c62828;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .pe-danger p { font-size: 13px; color: var(--muted); margin-bottom: 16px; }

    @media (max-width: 768px) {
        .pe-row { grid-template-columns: 1fr; }
        .pe-wrap { padding: 20px; }
    }
</style>
{% endblock %}

{% block body %}
<div class="pe-wrap">

    {# ── HEADER ── #}
    <div class="pe-header">
        <div>
            <h1><i class="fas fa-pen"></i> Edit Product</h1>
            <p>Update product details and nutrition information.</p>
        </div>
        <a href="{{ path('app_dashboard_product_show', {'id': product.id}) }}" class="pe-back">
            <i class="fas fa-arrow-left"></i> Back to Product
        </a>
    </div>

    {{ form_start(form) }}

        {# ── BASIC INFO ── #}
        <div class="pe-card">
            <div class="pe-card-title">
                <i class="fas fa-info-circle"></i> Basic Information
            </div>

            <label class="pe-label" for="{{ form.name.vars.id }}">
                <i class="fas fa-tag"></i> Product Name
            </label>
            {{ form_widget(form.name, {'attr': {'placeholder': 'e.g. Caramel Macchiato'}}) }}
            {{ form_errors(form.name) }}
            <div class="pe-help"><i class="fas fa-info-circle"></i> Enter the full name of the product.</div>

            <div class="pe-row">
                <div>
                    <label class="pe-label" for="{{ form.category.vars.id }}">
                        <i class="fas fa-list"></i> Category
                    </label>
                    {{ form_widget(form.category) }}
                    {{ form_errors(form.category) }}
                    <div class="pe-help"><i class="fas fa-info-circle"></i> Select a product category.</div>
                </div>
                <div>
                    <label class="pe-label" for="{{ form.price.vars.id }}">
                        <i class="fas fa-peso-sign"></i> Price (₱)
                    </label>
                    {{ form_widget(form.price, {'attr': {'placeholder': '0.00', 'step': '0.01'}}) }}
                    {{ form_errors(form.price) }}
                    <div class="pe-help"><i class="fas fa-info-circle"></i> Set the selling price in PHP.</div>
                </div>
            </div>
        </div>

        {# ── NUTRITION INFO ── #}
        <div class="pe-card pe-nut-card">
            <div class="pe-card-title">
                <i class="fas fa-clipboard-list"></i> Nutritional Information
            </div>

            <div class="pe-row">
                <div>
                    <label class="pe-label" for="{{ form.calories.vars.id }}">
                        <i class="fas fa-fire"></i> Calories (kcal)
                    </label>
                    {{ form_widget(form.calories, {'attr': {'placeholder': 'e.g. 250'}}) }}
                    {{ form_errors(form.calories) }}
                    <div class="pe-help"><i class="fas fa-info-circle"></i> Total calorie content per serving.</div>
                </div>
                <div>
                    <label class="pe-label" for="{{ form.sugarGrams.vars.id }}">
                        <i class="fas fa-cubes"></i> Sugar (g)
                    </label>
                    {{ form_widget(form.sugarGrams, {'attr': {'placeholder': 'e.g. 25.5', 'step': '0.1'}}) }}
                    {{ form_errors(form.sugarGrams) }}
                    <div class="pe-help"><i class="fas fa-info-circle"></i> Sugar content in grams per serving.</div>
                </div>
            </div>

            <label class="pe-label" for="{{ form.caffeineMg.vars.id }}">
                <i class="fas fa-bolt"></i> Caffeine (mg)
            </label>
            {{ form_widget(form.caffeineMg, {'attr': {'placeholder': 'e.g. 75'}}) }}
            {{ form_errors(form.caffeineMg) }}
            <div class="pe-help"><i class="fas fa-info-circle"></i> Caffeine content in milligrams per serving.</div>

            <div class="pe-actions">
                <button type="submit" class="pe-btn primary">
                    <i class="fas fa-check"></i> Update Product
                </button>
                <a href="{{ path('app_dashboard_product_show', {'id': product.id}) }}" class="pe-btn cancel">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </div>

    {{ form_end(form) }}

    {# ── DANGER ZONE ── #}
    <div class="pe-danger">
        <div class="pe-danger-title">
            <i class="fas fa-exclamation-triangle"></i> Danger Zone
        </div>
        <p>Once you delete this product, there is no going back. All associated data will be permanently removed.</p>
        {{ include('product/_delete_form.html.twig') }}
    </div>

</div>
{% endblock %}
