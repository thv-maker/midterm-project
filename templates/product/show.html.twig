{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Bincafe{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #c2410c;
        --brown-mid:   #ea580c;
        --brown-acc:   #f97316;
        --brown-light: #fdba74;
        --cream:       #fff7ed;
        --cream2:      #ffedd5;
        --white:       #ffffff;
        --text:        #431407;
        --muted:       #b45309;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .ps-wrap { padding: 32px 36px; }

    /* ── HEADER ── */
    .ps-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .ps-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .ps-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .ps-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .ps-back {
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15);
        color: #fff;
        padding: 10px 22px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .ps-back:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* ── PRODUCT PROFILE CARD ── */
    .ps-profile {
        background: var(--white);
        border-radius: 16px;
        padding: 28px 30px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 24px;
    }
    .ps-product-icon {
        width: 80px; height: 80px; min-width: 80px;
        background: var(--cream2);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: var(--brown-mid);
        font-size: 32px;
        border: 3px solid var(--cream2);
    }
    .ps-profile-info h2 {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        color: var(--text);
        margin: 0 0 8px;
        font-weight: 700;
    }
    .ps-profile-meta { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
    .ps-cat-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: var(--cream2);
        color: var(--brown-dark);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 20px;
    }
    .ps-id-badge {
        font-size: 12px;
        color: var(--muted);
        background: var(--cream);
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
    }

    /* ── PRICE CARD ── */
    .ps-price-card {
        background: var(--white);
        border-radius: 16px;
        padding: 28px 30px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        margin-bottom: 20px;
        text-align: center;
        border: 2px solid var(--cream2);
    }
    .ps-price-label {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 8px;
    }
    .ps-price {
        font-family: 'Playfair Display', serif;
        font-size: 48px;
        font-weight: 700;
        color: var(--brown-dark);
        line-height: 1;
    }

    /* ── INFO GRID ── */
    .ps-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }

    .ps-card {
        background: var(--white);
        border-radius: 16px;
        padding: 24px 26px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }
    .ps-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 16px;
        padding-bottom: 12px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .ps-card-title i { color: var(--brown-acc); }

    .ps-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1.5px solid var(--cream2);
    }
    .ps-row:last-child { border-bottom: none; }
    .ps-row-label {
        font-size: 13px;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 7px;
        font-weight: 500;
    }
    .ps-row-label i { color: var(--brown-light); font-size: 12px; width: 14px; }
    .ps-row-value { font-size: 14px; font-weight: 700; color: var(--text); }

    /* nutrition card accent */
    .ps-nut-card { border-left: 4px solid var(--brown-light); }

    /* ── ACTIONS ── */
    .ps-actions-card {
        background: var(--white);
        border-radius: 16px;
        padding: 24px 26px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        margin-bottom: 20px;
        display: flex;
        gap: 12px;
    }
    .ps-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 40px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: background .2s, transform .2s;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }
    .ps-btn.edit { background: var(--brown-dark); color: #fff; }
    .ps-btn.edit:hover { background: var(--brown-acc); color: #fff; transform: translateY(-2px); }
    .ps-btn.back { background: var(--cream2); color: var(--brown-dark); }
    .ps-btn.back:hover { background: #e0d4c5; transform: translateY(-2px); }

    /* ── DANGER ZONE ── */
    .ps-danger {
        background: var(--white);
        border-radius: 16px;
        padding: 24px 30px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        border-left: 4px solid #f44336;
    }
    .ps-danger-title {
        font-size: 15px;
        font-weight: 700;
        color: #c62828;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .ps-danger p { font-size: 13px; color: var(--muted); margin-bottom: 16px; }

    @media (max-width: 768px) {
        .ps-grid { grid-template-columns: 1fr; }
        .ps-wrap { padding: 20px; }
        .ps-profile { flex-direction: column; text-align: center; }
    }
</style>
{% endblock %}

{% block body %}
<div class="ps-wrap">

    {# ── HEADER ── #}
    <div class="ps-header">
        <div>
            <h1><i class="fas fa-coffee"></i> Product Details</h1>
            <p>View full product information and nutrition facts.</p>
        </div>
        <a href="{{ path('app_dashboard_products') }}" class="ps-back">
            <i class="fas fa-arrow-left"></i> Back to Products
        </a>
    </div>

    {# ── PROFILE ── #}
    <div class="ps-profile">
        <div class="ps-product-icon">
            <i class="fas fa-coffee"></i>
        </div>
        <div class="ps-profile-info">
            <h2>{{ product.name }}</h2>
            <div class="ps-profile-meta">
                <span class="ps-cat-badge"><i class="fas fa-tag"></i> {{ product.category|capitalize }}</span>
                <span class="ps-id-badge">#{{ product.id }}</span>
            </div>
        </div>
    </div>

    {# ── PRICE ── #}
    <div class="ps-price-card">
        <div class="ps-price-label">Selling Price</div>
        <div class="ps-price">₱{{ product.price|number_format(2) }}</div>
    </div>

    {# ── INFO GRID ── #}
    <div class="ps-grid">

        {# Product Info #}
        <div class="ps-card">
            <div class="ps-card-title">
                <i class="fas fa-info-circle"></i> Product Information
            </div>
            <div class="ps-row">
                <span class="ps-row-label"><i class="fas fa-tag"></i> Name</span>
                <span class="ps-row-value">{{ product.name }}</span>
            </div>
            <div class="ps-row">
                <span class="ps-row-label"><i class="fas fa-list"></i> Category</span>
                <span class="ps-row-value">{{ product.category|capitalize }}</span>
            </div>
            <div class="ps-row">
                <span class="ps-row-label"><i class="fas fa-hashtag"></i> Product ID</span>
                <span class="ps-row-value">#{{ product.id }}</span>
            </div>
        </div>

        {# Nutrition Info #}
        <div class="ps-card ps-nut-card">
            <div class="ps-card-title">
                <i class="fas fa-clipboard-list"></i> Nutritional Information
            </div>
            <div class="ps-row">
                <span class="ps-row-label"><i class="fas fa-fire"></i> Calories</span>
                <span class="ps-row-value">{{ product.calories }} kcal</span>
            </div>
            <div class="ps-row">
                <span class="ps-row-label"><i class="fas fa-cubes"></i> Sugar</span>
                <span class="ps-row-value">{{ product.sugarGrams }} g</span>
            </div>
            <div class="ps-row">
                <span class="ps-row-label"><i class="fas fa-bolt"></i> Caffeine</span>
                <span class="ps-row-value">{{ product.caffeineMg }} mg</span>
            </div>
        </div>

    </div>

    {# ── ACTIONS ── #}
    <div class="ps-actions-card">
        <a href="{{ path('app_dashboard_product_edit', {'id': product.id}) }}" class="ps-btn edit">
            <i class="fas fa-pen"></i> Edit Product
        </a>
        <a href="{{ path('app_dashboard_products') }}" class="ps-btn back">
            <i class="fas fa-list"></i> Back to List
        </a>
    </div>

    {# ── DANGER ZONE ── #}
    <div class="ps-danger">
        <div class="ps-danger-title">
            <i class="fas fa-exclamation-triangle"></i> Danger Zone
        </div>
        <p>Once you delete this product, there is no going back. All associated data will be permanently removed.</p>
        {{ include('product/_delete_form.html.twig') }}
    </div>

</div>
{% endblock %}
