<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Bincafe</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #fff7ed;
            min-height: 100vh;
        }

        .login-wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* LEFT SIDE */
        .login-left {
            flex: 0 0 55%;
            background: #c2410c;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 80px 70px;
            position: relative;
            overflow: hidden;
        }
        .login-left::before {
            content: '';
            position: absolute;
            top: -100px; right: -100px;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: rgba(255,255,255,.04);
        }
        .login-left::after {
            content: '';
            position: absolute;
            bottom: -80px; left: -80px;
            width: 300px; height: 300px;
            border-radius: 50%;
            background: rgba(255,255,255,.03);
        }
        .login-brand {
            font-family: 'Playfair Display', serif;
            font-size: 42px;
            color: #fff;
            margin-bottom: 10px;
            position: relative; z-index: 1;
        }
        .login-brand span { color: #fdba74; }
        .login-tagline {
            font-size: 15px;
            color: rgba(255,255,255,.6);
            margin-bottom: 50px;
            position: relative; z-index: 1;
        }
        .login-features {
            display: flex;
            flex-direction: column;
            gap: 20px;
            position: relative; z-index: 1;
        }
        .login-feat {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .login-feat-icon {
            width: 46px; height: 46px; min-width: 46px;
            background: rgba(255,255,255,.08);
            border: 1.5px solid rgba(255,255,255,.12);
            border-radius: 12px;
            display: flex; align-items: center;
            justify-content: center; font-size: 20px;
        }
        .login-feat-text h5 {
            font-size: 14px; font-weight: 700;
            color: #fff; margin-bottom: 2px;
        }
        .login-feat-text p {
            font-size: 13px;
            color: rgba(255,255,255,.55); margin: 0;
        }

        /* RIGHT SIDE */
        .login-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 50px;
            background: #fff7ed;
        }
        .login-card {
            width: 100%;
            max-width: 400px;
        }
        .login-card h2 {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            color: #431407;
            margin-bottom: 6px;
        }
        .login-card h2 span { color: #f97316; }
        .login-card .sub {
            font-size: 14px;
            color: #b45309;
            margin-bottom: 36px;
        }

        /* Override Symfony form styles */
        .login-card label {
            display: block; font-size: 13px;
            font-weight: 600; color: #431407;
            margin-bottom: 7px;
        }
        .login-card input[type="email"],
        .login-card input[type="password"],
        .login-card input[type="text"] {
            width: 100%; padding: 12px 16px;
            border: 1.5px solid #ffedd5;
            border-radius: 10px; font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            color: #431407; background: #fff;
            outline: none; transition: border-color .2s;
            margin-bottom: 20px;
        }
        .login-card input[type="email"]:focus,
        .login-card input[type="password"]:focus,
        .login-card input[type="text"]:focus {
            border-color: #f97316;
        }
        .login-card .form-check {
            display: flex; align-items: center;
            gap: 8px; margin-bottom: 24px;
        }
        .login-card .form-check input[type="checkbox"] {
            accent-color: #c2410c;
            width: 15px; height: 15px;
            margin: 0;
        }
        .login-card .form-check label {
            font-size: 13px; color: #b45309;
            font-weight: 400; margin: 0;
        }
        .login-card .invalid-feedback,
        .login-card .form-error {
            font-size: 12px; color: #c62828;
            margin-top: -14px; margin-bottom: 12px;
            display: block;
        }

        .btn-login {
            width: 100%; padding: 14px;
            background: #c2410c; color: #fff;
            border: none; border-radius: 40px;
            font-size: 15px; font-weight: 700;
            cursor: pointer; transition: background .2s;
            font-family: 'DM Sans', sans-serif;
            display: flex; align-items: center;
            justify-content: center; gap: 8px;
        }
        .btn-login:hover { background: #f97316; }

        .back-link {
            display: block; text-align: center;
            margin-top: 20px; font-size: 13px;
            color: #b45309; text-decoration: none;
            transition: color .2s;
        }
        .back-link:hover { color: #c2410c; }

        .alert-error {
            background: #ffebee; color: #c62828;
            border: 1.5px solid #ffcdd2;
            border-radius: 10px; padding: 12px 16px;
            font-size: 13px; margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .login-left { display: none; }
            .login-right { padding: 40px 24px; }
        }
    </style>
</head>
<body>
<div class="login-wrapper">

    {# LEFT SIDE #}
    <div class="login-left">
        <div class="login-brand">● Bin<span>cafe</span></div>
        <div class="login-tagline">One cup at a time.</div>
        <div class="login-features">
            <div class="login-feat">
                <div class="login-feat-icon">📋</div>
                <div class="login-feat-text">
                    <h5>Nutrition Facts on Every Cup</h5>
                    <p>The only café with full transparency on every drink.</p>
                </div>
            </div>
            <div class="login-feat">
                <div class="login-feat-icon">🫘</div>
                <div class="login-feat-text">
                    <h5>Locally Sourced Beans</h5>
                    <p>Fresh, fair-trade coffee from local farms daily.</p>
                </div>
            </div>
            <div class="login-feat">
                <div class="login-feat-icon">✅</div>
                <div class="login-feat-text">
                    <h5>Zero Hidden Ingredients</h5>
                    <p>100% transparent — what you see is what you get.</p>
                </div>
            </div>
        </div>
    </div>

    {# RIGHT SIDE #}
    <div class="login-right">
        <div class="login-card">
            <h2>Create an <span>Account</span></h2>
            <p class="sub">Join Bincafe and enjoy full nutrition transparency in every cup.</p>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}

                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.plainPassword, { label: 'Password' }) }}
                {{ form_row(registrationForm.agreeTerms) }}

                <button type="submit" class="btn-login">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width:18px;height:18px;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Create Account
                </button>

            {{ form_end(registrationForm) }}

            <a href="{{ path('app_login') }}" class="back-link">Already have an account? Sign In</a>
        </div>
    </div>

</div>
</body>
</html>
