{% extends 'base.html.twig' %}

{% block title %}User Management{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #1d4ed8;
        --brown-mid:   #2563eb;
        --brown-acc:   #3b82f6;
        --brown-light: #93c5fd;
        --cream:       #eff6ff;
        --cream2:      #dbeafe;
        --white:       #ffffff;
        --text:        #1e293b;
        --muted:       #64748b;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .um-wrap { padding: 32px 36px; }

    /* ── HEADER ── */
    .um-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .um-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .um-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .um-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .um-add-btn {
        background: rgba(255,255,255,.12);
        border: 1.5px solid rgba(255,255,255,.2);
        color: #fff;
        padding: 11px 24px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .um-add-btn:hover { background: rgba(255,255,255,.2); color: #fff; }

    /* ── TABLE CARD ── */
    .um-card {
        background: var(--white);
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        overflow: hidden;
    }
    .um-card-head {
        padding: 22px 28px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .um-card-head h3 {
        font-family: 'Playfair Display', serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .um-card-head h3 i { color: var(--brown-acc); }
    .um-count {
        font-size: 13px;
        color: var(--muted);
        font-weight: 500;
    }

    /* ── TABLE ── */
    table.um-table { width: 100%; border-collapse: collapse; }
    table.um-table thead th {
        padding: 12px 18px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--cream);
        border-bottom: 2px solid var(--cream2);
    }
    table.um-table tbody td {
        padding: 16px 18px;
        font-size: 13px;
        color: var(--text);
        border-bottom: 1.5px solid var(--cream2);
        vertical-align: middle;
    }
    table.um-table tbody tr:last-child td { border-bottom: none; }
    table.um-table tbody tr:hover td { background: var(--cream); }

    /* user cell */
    .um-user-cell { display: flex; align-items: center; gap: 12px; }
    .um-avatar {
        width: 38px; height: 38px;
        border-radius: 50%;
        background: var(--cream2);
        display: flex; align-items: center; justify-content: center;
        color: var(--brown-mid);
        font-size: 15px;
        flex-shrink: 0;
    }
    .um-user-email { font-weight: 600; color: var(--text); font-size: 13px; }
    .um-user-id { font-size: 11px; color: var(--muted); }

    /* badges */
    .um-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
    }
    .um-badge.admin  { background: var(--cream2); color: var(--brown-dark); }
    .um-badge.staff  { background: #fff3e0; color: #e65100; }
    .um-badge.user   { background: #f3e5f5; color: #7b1fa2; }
    .um-badge.active   { background: #e8f5e9; color: #2e7d32; }
    .um-badge.inactive { background: #ffebee; color: #c62828; }

    /* action buttons */
    .um-actions { display: flex; gap: 6px; flex-wrap: wrap; }
    .um-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: opacity .2s, transform .2s;
    }
    .um-btn:hover { opacity: .85; transform: translateY(-1px); }
    .um-btn.view     { background: var(--cream2); color: var(--brown-dark); }
    .um-btn.edit     { background: #fff3e0; color: #e65100; }
    .um-btn.activate { background: #e8f5e9; color: #2e7d32; }
    .um-btn.deactivate { background: #fff3e0; color: #e65100; }
    .um-btn.delete   { background: #ffebee; color: #c62828; }
    .um-btn-form { display: inline; }

    /* empty */
    .um-empty { text-align: center; padding: 60px 20px; color: var(--muted); }
    .um-empty i { font-size: 48px; opacity: .3; margin-bottom: 16px; display: block; }
    .um-empty p { font-size: 15px; margin: 0; }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const rowUrlTemplate = {{ path('app_user_row', { id: 0 })|json_encode|raw }}.replace('/0', '/');
            const tbody = document.getElementById('um-users-tbody');
            const countEl = document.querySelector('.um-count');
            const knownIds = new Set(
                [...document.querySelectorAll('[data-user-id]')].map(el => parseInt(el.dataset.userId, 10))
            );

            function updateCount() {
                if (countEl) {
                    const n = tbody ? tbody.querySelectorAll('[data-user-id]').length : 0;
                    countEl.textContent = n + ' user' + (n !== 1 ? 's' : '') + ' found';
                }
            }

            async function fetchRow(userId) {
                const response = await fetch(rowUrlTemplate + userId, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                });
                if (!response.ok) throw new Error('Failed to load user row');
                return response.text();
            }

            async function insertRow(userId) {
                if (!tbody || knownIds.has(userId)) return;
                const html = await fetchRow(userId);
                const template = document.createElement('template');
                template.innerHTML = html.trim();
                const row = template.content.querySelector('[data-user-id]');
                if (!row) return;
                tbody.insertBefore(row, tbody.firstChild);
                knownIds.add(userId);
                updateCount();
            }

            async function refreshRow(userId) {
                if (!tbody) return;
                const existing = tbody.querySelector('[data-user-id="' + userId + '"]');
                if (!existing) return insertRow(userId);
                const html = await fetchRow(userId);
                const template = document.createElement('template');
                template.innerHTML = html.trim();
                const row = template.content.querySelector('[data-user-id]');
                if (row) existing.replaceWith(row);
            }

            async function handleEvent(payload) {
                if (!payload?.userId) return;
                if (payload.type === 'deleted') {
                    const el = tbody?.querySelector('[data-user-id="' + payload.userId + '"]');
                    if (el) {
                        el.remove();
                        knownIds.delete(payload.userId);
                        updateCount();
                    }
                    return;
                }
                if (payload.type === 'created') {
                    await insertRow(payload.userId);
                    return;
                }
                if (payload.type === 'updated') {
                    await refreshRow(payload.userId);
                }
            }

            try {
                CafeRealtime.connect('/users', (_topic, payload) => handleEvent(payload));
            } catch (e) {
                console.warn('WebSocket unavailable for users', e);
            }
        })();
    </script>
{% endblock %}

{% block body %}
<div class="um-wrap">

    {# ── HEADER ── #}
    <div class="um-header">
        <div>
            <h1><i class="fas fa-users"></i> User Management</h1>
            <p>Manage all registered users and their permissions.</p>
        </div>
        <a href="{{ path('app_user_new') }}" class="um-add-btn">
            <i class="fas fa-plus"></i> Add New User
        </a>
    </div>

    {# ── TABLE CARD ── #}
    <div class="um-card">
        <div class="um-card-head">
            <h3><i class="fas fa-list"></i> All Users</h3>
            <span class="um-count">{{ users|length }} user{{ users|length != 1 ? 's' : '' }} found</span>
        </div>

        {% if users is empty %}
            <div class="um-empty">
                <i class="fas fa-users"></i>
                <p>No users found in the system.</p>
            </div>
        {% else %}
            <div style="overflow-x:auto;">
                <table class="um-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Last Login</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="um-users-tbody">
                        {% for user in users %}
                        {% include 'user/_row.html.twig' %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
