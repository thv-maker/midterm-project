{% extends 'base.html.twig' %}

{% block title %}Activity Logs - {{ action|upper }}{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #3e1f0d;
        --brown-mid:   #6d4c41;
        --brown-acc:   #8B5E3C;
        --brown-light: #c49a6c;
        --cream:       #faf7f4;
        --cream2:      #f3ece4;
        --white:       #ffffff;
        --text:        #2b1a0f;
        --muted:       #9e8070;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .ba-wrap { padding: 32px 36px; }

    /* ── HEADER ── */
    .ba-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .ba-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .ba-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .ba-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .ba-btns { display: flex; gap: 10px; position: relative; z-index: 1; }
    .ba-btn-back {
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15);
        color: #fff;
        padding: 10px 20px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .ba-btn-back:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* ── STAT ── */
    .ba-stat {
        background: var(--white);
        border-radius: 16px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        border-left: 4px solid var(--brown-acc);
        margin-bottom: 24px;
        transition: transform .3s, box-shadow .3s;
    }
    .ba-stat:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(0,0,0,.09); }
    .ba-stat-icon {
        width: 60px; height: 60px;
        border-radius: 14px;
        background: var(--cream2);
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
        color: var(--brown-mid);
        flex-shrink: 0;
    }
    .ba-stat-label { font-size: 11px; color: var(--muted); font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
    .ba-stat-value { font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 700; color: var(--text); line-height: 1; }

    /* ── FILTER ── */
    .ba-filter-card {
        background: var(--white);
        border-radius: 16px;
        padding: 24px 26px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        margin-bottom: 24px;
    }
    .ba-filter-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .ba-filter-title i { color: var(--brown-acc); }
    .ba-filters { display: flex; flex-wrap: wrap; gap: 10px; }
    .ba-filter-btn {
        padding: 8px 20px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        border: 1.5px solid var(--cream2);
        background: var(--cream);
        color: var(--muted);
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .ba-filter-btn:hover { background: var(--brown-dark); color: #fff; border-color: var(--brown-dark); }
    .ba-filter-btn.active { background: var(--brown-dark); color: #fff; border-color: var(--brown-dark); }
    .ba-filter-btn.f-login.active,  .ba-filter-btn.f-login:hover  { background: #2e7d32; border-color: #2e7d32; color: #fff; }
    .ba-filter-btn.f-logout.active, .ba-filter-btn.f-logout:hover { background: #546e7a; border-color: #546e7a; color: #fff; }
    .ba-filter-btn.f-create.active, .ba-filter-btn.f-create:hover { background: #1565c0; border-color: #1565c0; color: #fff; }
    .ba-filter-btn.f-update.active, .ba-filter-btn.f-update:hover { background: #e65100; border-color: #e65100; color: #fff; }
    .ba-filter-btn.f-delete.active, .ba-filter-btn.f-delete:hover { background: #c62828; border-color: #c62828; color: #fff; }

    /* ── TABLE CARD ── */
    .ba-table-card {
        background: var(--white);
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        overflow: hidden;
    }
    .ba-table-head {
        padding: 22px 26px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Playfair Display', serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
    }
    .ba-table-head i { color: var(--brown-acc); font-size: 15px; }

    table.ba-table { width: 100%; border-collapse: collapse; }
    table.ba-table thead th {
        padding: 12px 16px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--cream);
        border-bottom: 2px solid var(--cream2);
    }
    table.ba-table tbody td {
        padding: 14px 16px;
        font-size: 13px;
        color: var(--text);
        border-bottom: 1.5px solid var(--cream2);
        vertical-align: middle;
    }
    table.ba-table tbody tr:last-child td { border-bottom: none; }
    table.ba-table tbody tr:hover td { background: var(--cream); }

    .ba-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
    }
    .ba-badge.role   { background: var(--cream2); color: var(--brown-dark); }
    .ba-badge.login  { background: #e8f5e9; color: #2e7d32; }
    .ba-badge.logout { background: #eceff1; color: #546e7a; }
    .ba-badge.create { background: #e3f2fd; color: #1565c0; }
    .ba-badge.update { background: #fff3e0; color: #e65100; }
    .ba-badge.delete { background: #ffebee; color: #c62828; }

    .ba-user-link {
        color: var(--brown-acc);
        text-decoration: none;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .ba-user-link:hover { color: var(--brown-dark); text-decoration: underline; }
    .ba-timestamp { color: var(--muted); font-size: 12px; line-height: 1.6; }
    .ba-ip { font-family: 'Courier New', monospace; color: var(--muted); font-size: 12px; }
    .ba-empty { text-align: center; padding: 50px 20px; color: var(--muted); }
    .ba-empty i { font-size: 40px; margin-bottom: 14px; opacity: .4; display: block; }
</style>
{% endblock %}

{% block body %}
<div class="ba-wrap">

    {# ── HEADER ── #}
    <div class="ba-header">
        <div>
            <h1>
                {% if action == 'login' %}<i class="fas fa-sign-in-alt"></i>
                {% elseif action == 'logout' %}<i class="fas fa-sign-out-alt"></i>
                {% elseif action == 'create' %}<i class="fas fa-plus"></i>
                {% elseif action == 'update' %}<i class="fas fa-edit"></i>
                {% elseif action == 'delete' %}<i class="fas fa-trash"></i>
                {% else %}<i class="fas fa-list"></i>{% endif %}
                {{ action|upper }} Activities
            </h1>
            <p>Showing all {{ action|lower }} activities in the system</p>
        </div>
        <div class="ba-btns">
            <a href="{{ path('app_activity_log_index') }}" class="ba-btn-back">
                <i class="fas fa-arrow-left"></i> All Logs
            </a>
            <a href="{{ path('app_dashboard_index') }}" class="ba-btn-back">
                <i class="fas fa-home"></i> Dashboard
            </a>
        </div>
    </div>

    {# ── STAT ── #}
    <div class="ba-stat">
        <div class="ba-stat-icon">
            {% if action == 'login' %}<i class="fas fa-sign-in-alt"></i>
            {% elseif action == 'logout' %}<i class="fas fa-sign-out-alt"></i>
            {% elseif action == 'create' %}<i class="fas fa-plus"></i>
            {% elseif action == 'update' %}<i class="fas fa-edit"></i>
            {% elseif action == 'delete' %}<i class="fas fa-trash"></i>
            {% else %}<i class="fas fa-list"></i>{% endif %}
        </div>
        <div>
            <div class="ba-stat-label">{{ action|upper }} Activities</div>
            <div class="ba-stat-value">{{ logs|length }}</div>
        </div>
    </div>

    {# ── FILTERS ── #}
    <div class="ba-filter-card">
        <div class="ba-filter-title">
            <i class="fas fa-filter"></i> Filter by Action
        </div>
        <div class="ba-filters">
            <a href="{{ path('app_activity_log_index') }}" class="ba-filter-btn">
                <i class="fas fa-list"></i> All
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'login'}) }}"
               class="ba-filter-btn f-login {{ action == 'login' ? 'active' : '' }}">
                <i class="fas fa-sign-in-alt"></i> Login
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'logout'}) }}"
               class="ba-filter-btn f-logout {{ action == 'logout' ? 'active' : '' }}">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'create'}) }}"
               class="ba-filter-btn f-create {{ action == 'create' ? 'active' : '' }}">
                <i class="fas fa-plus"></i> Create
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'update'}) }}"
               class="ba-filter-btn f-update {{ action == 'update' ? 'active' : '' }}">
                <i class="fas fa-edit"></i> Update
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'delete'}) }}"
               class="ba-filter-btn f-delete {{ action == 'delete' ? 'active' : '' }}">
                <i class="fas fa-trash"></i> Delete
            </a>
        </div>
    </div>

    {# ── TABLE ── #}
    <div class="ba-table-card">
        <div class="ba-table-head">
            <i class="fas fa-clipboard-list"></i> {{ action|upper }} Activity Records
        </div>
        <div style="overflow-x:auto;">
            <table class="ba-table">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Action</th>
                        <th>Target Data</th>
                        <th>Date & Time</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                    <tr>
                        <td><strong style="color:var(--muted);">#{{ log.userId }}</strong></td>
                        <td>
                            <a href="{{ path('app_activity_log_by_user', {userId: log.userId}) }}" class="ba-user-link">
                                <i class="fas fa-user" style="font-size:11px;"></i>
                                {{ log.username }}
                            </a>
                        </td>
                        <td><span class="ba-badge role">{{ log.formattedRole }}</span></td>
                        <td>
                            <span class="ba-badge {{ log.action|lower }}">
                                {% if log.action == 'LOGIN' %}<i class="fas fa-sign-in-alt"></i>
                                {% elseif log.action == 'LOGOUT' %}<i class="fas fa-sign-out-alt"></i>
                                {% elseif log.action == 'CREATE' %}<i class="fas fa-plus"></i>
                                {% elseif log.action == 'UPDATE' %}<i class="fas fa-edit"></i>
                                {% elseif log.action == 'DELETE' %}<i class="fas fa-trash"></i>
                                {% endif %}
                                {{ log.action }}
                            </span>
                        </td>
                        <td>{{ log.targetData }}</td>
                        <td>
                            <div class="ba-timestamp">
                                <i class="far fa-clock"></i>
                                {{ log.dateTime|date('M d, Y') }}<br>
                                <small>{{ log.dateTime|date('h:i:s A') }}</small>
                            </div>
                        </td>
                        <td>
                            <span class="ba-ip">
                                <i class="fas fa-globe"></i>
                                {{ log.ipAddress ?? 'N/A' }}
                            </span>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7">
                            <div class="ba-empty">
                                <i class="fas fa-inbox"></i>
                                <strong>No {{ action|upper }} Activities Found</strong>
                                <p style="margin:6px 0 0; font-size:13px;">There are no {{ action|lower }} activities recorded yet.</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}
