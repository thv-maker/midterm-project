{% extends 'base.html.twig' %}

{% block title %}Activity Logs{% endblock %}

{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
    :root {
        --brown-dark:  #3e1f0d;
        --brown-mid:   #6d4c41;
        --brown-acc:   #8B5E3C;
        --brown-light: #c49a6c;
        --cream:       #faf7f4;
        --cream2:      #f3ece4;
        --white:       #ffffff;
        --text:        #2b1a0f;
        --muted:       #9e8070;
    }

    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

    .al-wrap { padding: 32px 36px; }

    /* ── HEADER ── */
    .al-header {
        background: var(--brown-dark);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .al-header::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }
    .al-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 24px;
        color: #fff;
        margin: 0 0 4px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .al-header p { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }
    .al-back {
        background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15);
        color: #fff;
        padding: 10px 22px;
        border-radius: 30px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: background .2s;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative; z-index: 1;
    }
    .al-back:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* ── STATS ── */
    .al-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }
    .al-stat {
        background: var(--white);
        border-radius: 16px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 18px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        border-left: 4px solid var(--brown-acc);
        transition: transform .3s, box-shadow .3s;
    }
    .al-stat:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(0,0,0,.09); }
    .al-stat-icon {
        width: 54px; height: 54px;
        border-radius: 14px;
        background: var(--cream2);
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
        color: var(--brown-mid);
        flex-shrink: 0;
    }
    .al-stat-label { font-size: 11px; color: var(--muted); font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
    .al-stat-value { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: var(--text); line-height: 1; }

    /* ── FILTER ── */
    .al-filter-card {
        background: var(--white);
        border-radius: 16px;
        padding: 24px 26px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        margin-bottom: 24px;
    }
    .al-filter-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .al-filter-title i { color: var(--brown-acc); }
    .al-filters { display: flex; flex-wrap: wrap; gap: 10px; }
    .al-filter-btn {
        padding: 8px 20px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        border: 1.5px solid var(--cream2);
        background: var(--cream);
        color: var(--muted);
        transition: all .2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .al-filter-btn:hover,
    .al-filter-btn.active {
        background: var(--brown-dark);
        color: #fff;
        border-color: var(--brown-dark);
    }
    .al-filter-btn.f-login:hover   { background: #2e7d32; border-color: #2e7d32; }
    .al-filter-btn.f-logout:hover  { background: #546e7a; border-color: #546e7a; }
    .al-filter-btn.f-create:hover  { background: #1565c0; border-color: #1565c0; }
    .al-filter-btn.f-update:hover  { background: #e65100; border-color: #e65100; }
    .al-filter-btn.f-delete:hover  { background: #c62828; border-color: #c62828; }

    /* ── TABLE CARD ── */
    .al-table-card {
        background: var(--white);
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        overflow: hidden;
    }
    .al-table-head {
        padding: 22px 26px;
        border-bottom: 1.5px solid var(--cream2);
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Playfair Display', serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
    }
    .al-table-head i { color: var(--brown-acc); font-size: 15px; }

    table.al-table { width: 100%; border-collapse: collapse; }
    table.al-table thead th {
        padding: 12px 16px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--muted);
        background: var(--cream);
        border-bottom: 2px solid var(--cream2);
    }
    table.al-table tbody td {
        padding: 14px 16px;
        font-size: 13px;
        color: var(--text);
        border-bottom: 1.5px solid var(--cream2);
        vertical-align: middle;
    }
    table.al-table tbody tr:last-child td { border-bottom: none; }
    table.al-table tbody tr:hover td { background: var(--cream); }

    /* badges */
    .al-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
    }
    .al-badge.role   { background: var(--cream2); color: var(--brown-dark); }
    .al-badge.login  { background: #e8f5e9; color: #2e7d32; }
    .al-badge.logout { background: #eceff1; color: #546e7a; }
    .al-badge.create { background: #e3f2fd; color: #1565c0; }
    .al-badge.update { background: #fff3e0; color: #e65100; }
    .al-badge.delete { background: #ffebee; color: #c62828; }
    .al-badge.order  { background: #e8eaf6; color: #3949ab; }
    .al-badge.register { background: #e0f7fa; color: #00838f; }

    .al-user-link {
        color: var(--brown-acc);
        text-decoration: none;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .al-user-link:hover { color: var(--brown-dark); text-decoration: underline; }
    .al-timestamp { color: var(--muted); font-size: 12px; line-height: 1.6; }
    .al-ip { font-family: 'Courier New', monospace; color: var(--muted); font-size: 12px; }

    .al-empty {
        text-align: center;
        padding: 50px 20px;
        color: var(--muted);
    }
    .al-empty i { font-size: 40px; margin-bottom: 14px; opacity: .4; display: block; }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const rowUrlTemplate = {{ path('app_activity_log_row', { id: 0 })|json_encode|raw }}.replace('/0', '/');
            const statsUrl = {{ path('app_activity_log_stats')|json_encode|raw }};
            const tbody = document.getElementById('al-logs-tbody');
            const knownIds = new Set(
                [...document.querySelectorAll('[data-log-id]')].map(el => parseInt(el.dataset.logId, 10))
            );

            async function refreshStats() {
                try {
                    const response = await fetch(statsUrl, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        credentials: 'same-origin',
                    });
                    if (!response.ok) return;
                    const data = await response.json();
                    const totalEl = document.getElementById('al-stat-total');
                    const todayEl = document.getElementById('al-stat-today');
                    const recentEl = document.getElementById('al-stat-recent');
                    if (totalEl) totalEl.textContent = data.total;
                    if (todayEl) todayEl.textContent = data.today;
                    if (recentEl && tbody) {
                        recentEl.textContent = tbody.querySelectorAll('[data-log-id]').length;
                    }
                } catch (e) {
                    console.warn('Failed to refresh activity stats', e);
                }
            }

            async function fetchRow(logId) {
                const response = await fetch(rowUrlTemplate + logId, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                });
                if (!response.ok) throw new Error('Failed to load log row');
                return response.text();
            }

            async function insertRow(logId) {
                if (!tbody || knownIds.has(logId)) return;
                const emptyRow = document.getElementById('al-empty-row');
                if (emptyRow) emptyRow.remove();
                const html = await fetchRow(logId);
                const template = document.createElement('template');
                template.innerHTML = html.trim();
                const row = template.content.querySelector('[data-log-id]');
                if (!row) return;
                tbody.insertBefore(row, tbody.firstChild);
                knownIds.add(logId);
                while (tbody.children.length > 100) {
                    const last = tbody.lastElementChild;
                    if (last?.dataset?.logId) knownIds.delete(parseInt(last.dataset.logId, 10));
                    last?.remove();
                }
                refreshStats();
            }

            async function handleEvent(payload) {
                if (payload?.type === 'created' && payload.logId) {
                    await insertRow(payload.logId);
                }
            }

            try {
                CafeRealtime.connect('/activity-logs', (_topic, payload) => handleEvent(payload));
            } catch (e) {
                console.warn('WebSocket unavailable for activity logs', e);
            }
        })();
    </script>
{% endblock %}

{% block body %}
<div class="al-wrap">

    {# ── HEADER ── #}
    <div class="al-header">
        <div>
            <h1><i class="fas fa-history"></i> Activity Logs</h1>
            <p>Monitor all system activities and user actions</p>
        </div>
        <a href="{{ path('app_dashboard_index') }}" class="al-back">
            <i class="fas fa-arrow-left"></i> Dashboard
        </a>
    </div>

    {# ── STATS ── #}
    <div class="al-stats">
        <div class="al-stat">
            <div class="al-stat-icon"><i class="fas fa-database"></i></div>
            <div>
                <div class="al-stat-label">Total Logs</div>
                <div class="al-stat-value" id="al-stat-total">{{ statistics.total }}</div>
            </div>
        </div>
        <div class="al-stat">
            <div class="al-stat-icon"><i class="fas fa-calendar-day"></i></div>
            <div>
                <div class="al-stat-label">Today's Activity</div>
                <div class="al-stat-value" id="al-stat-today">{{ statistics.today }}</div>
            </div>
        </div>
        <div class="al-stat">
            <div class="al-stat-icon"><i class="fas fa-chart-line"></i></div>
            <div>
                <div class="al-stat-label">Recent Actions</div>
                <div class="al-stat-value" id="al-stat-recent">{{ logs|length }}</div>
            </div>
        </div>
    </div>

    {# ── FILTERS ── #}
    <div class="al-filter-card">
        <div class="al-filter-title">
            <i class="fas fa-filter"></i> Filter by Action
        </div>
        <div class="al-filters">
            <a href="{{ path('app_activity_log_index') }}" class="al-filter-btn">
                <i class="fas fa-list"></i> All
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'login'}) }}" class="al-filter-btn f-login">
                <i class="fas fa-sign-in-alt"></i> Login
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'logout'}) }}" class="al-filter-btn f-logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'register'}) }}" class="al-filter-btn f-register">
                <i class="fas fa-user-plus"></i> Register
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'order'}) }}" class="al-filter-btn f-order">
                <i class="fas fa-shopping-cart"></i> Orders
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'create'}) }}" class="al-filter-btn f-create">
                <i class="fas fa-plus"></i> Create
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'update'}) }}" class="al-filter-btn f-update">
                <i class="fas fa-edit"></i> Update
            </a>
            <a href="{{ path('app_activity_log_by_action', {action: 'delete'}) }}" class="al-filter-btn f-delete">
                <i class="fas fa-trash"></i> Delete
            </a>
        </div>
    </div>

    {# ── TABLE ── #}
    <div class="al-table-card">
        <div class="al-table-head">
            <i class="fas fa-clipboard-list"></i> Recent Activity
        </div>
        <div style="overflow-x:auto;">
            <table class="al-table">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Action</th>
                        <th>Target Data</th>
                        <th>Date & Time</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody id="al-logs-tbody">
                    {% for log in logs %}
                    {% include 'activity_log/_row.html.twig' %}
                    {% else %}
                    <tr id="al-empty-row">
                        <td colspan="7">
                            <div class="al-empty">
                                <i class="fas fa-inbox"></i>
                                <strong>No Activity Logs Found</strong>
                                <p style="margin:6px 0 0; font-size:13px;">There are no recorded activities yet.</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}
